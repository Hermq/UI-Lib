        -- ── AddSection ──────────────────────────────────────
        function Tab:AddSection(sopts)
            local sName=sopts.Name or "Section"
            local HDR_H = 28   -- height of the header row
            local DIV_H = 1    -- divider
            local CLIP_TOP = HDR_H + DIV_H  -- where clip starts

            local sec=Instance.new("Frame")
            sec.Name="S_"..sName
            -- Start with just the header height; we'll grow it when content loads
            sec.Size=UDim2.new(1,0,0,HDR_H)
            sec.AutomaticSize=Enum.AutomaticSize.None   -- we drive height manually
            sec.BorderSizePixel=0
            sec.LayoutOrder=#page:GetChildren(); sec.ZIndex=12
            sec.ClipsDescendants=false; sec.Parent=page
            R(sec,"BackgroundColor3","SecondaryBg"); MakeCorner(sec,8)

            -- Collapsible header button
            local secHdrBtn=Instance.new("TextButton")
            secHdrBtn.Size=UDim2.new(1,0,0,HDR_H)
            secHdrBtn.BackgroundTransparency=1; secHdrBtn.Text=""
            secHdrBtn.BorderSizePixel=0; secHdrBtn.AutoButtonColor=false
            secHdrBtn.ZIndex=13; secHdrBtn.Parent=sec

            local secHdr=MakeLabel({
                Size=UDim2.new(1,-32,0,24),Position=UDim2.new(0,10,0,2),
                Text=sName,Font=Enum.Font.GothamBold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=14,Parent=secHdrBtn})
            R(secHdr,"TextColor3","Accent")

            -- Arrow: ◀ collapsed → rotates -90° (points down) when expanded
            local secArrow=MakeLabel({
                Size=UDim2.new(0,20,0,24),Position=UDim2.new(1,-24,0,2),
                Text="◀",TextSize=11,Font=Enum.Font.GothamBold,ZIndex=14,Parent=secHdrBtn})
            R(secArrow,"TextColor3","TextDim")

            local secDiv=MakeFrame({
                Size=UDim2.new(1,-20,0,DIV_H),
                Position=UDim2.new(0,10,0,HDR_H-1),
                ZIndex=13,Parent=sec})
            R(secDiv,"BackgroundColor3","Border")

            -- Clip: sits below header, clips the elems when collapsing
            local secClip=MakeFrame({
                Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,0,CLIP_TOP),
                BackgroundTransparency=1,ClipsDescendants=true,
                ZIndex=12,Parent=sec})

            -- Inner frame: auto-sizes to its children
            local elems=Instance.new("Frame")
            elems.Name="Elems"; elems.Size=UDim2.new(1,0,0,0)
            elems.AutomaticSize=Enum.AutomaticSize.Y
            elems.BackgroundTransparency=1; elems.BorderSizePixel=0
            elems.ZIndex=13; elems.Parent=secClip
            local eLL=Instance.new("UIListLayout")
            eLL.SortOrder=Enum.SortOrder.LayoutOrder; eLL.Parent=elems
            local ePd=Instance.new("UIPadding")
            ePd.PaddingBottom=UDim.new(0,6); ePd.Parent=elems

            -- Helper: set the outer sec height = header + clip height
            local function setSectionHeight(clipH)
                sec.Size = UDim2.new(1,0,0, CLIP_TOP + clipH)
            end

            local secExpanded = false  -- start collapsed; expand after first layout

            local function secExpand()
                secExpanded = true
                secDiv.Visible = true
                Tween(secArrow, {Rotation=-90}, 0.18)
                task.wait()   -- let elems layout settle
                local contentH = elems.AbsoluteSize.Y
                TweenSine(secClip, {Size=UDim2.new(1,0,0,contentH)}, 0.2)
                -- Drive outer frame height in sync
                local startH = sec.Size.Y.Offset
                local targetH = CLIP_TOP + contentH
                local steps = 10
                for i=1,steps do
                    task.wait(0.02)
                    if not secExpanded then break end
                    local t = i/steps
                    sec.Size = UDim2.new(1,0,0, math.floor(startH + (targetH-startH)*t + 0.5))
                end
                if secExpanded then sec.Size = UDim2.new(1,0,0, targetH) end
            end

            local function secCollapse()
                secExpanded = false
                secDiv.Visible = false
                Tween(secArrow, {Rotation=0}, 0.18)
                TweenSine(secClip, {Size=UDim2.new(1,0,0,0)}, 0.18)
                local startH = sec.Size.Y.Offset
                local targetH = HDR_H
                local steps = 9
                for i=1,steps do
                    task.wait(0.02)
                    if secExpanded then break end
                    local t = i/steps
                    sec.Size = UDim2.new(1,0,0, math.floor(startH + (targetH-startH)*t + 0.5))
                end
                if not secExpanded then sec.Size = UDim2.new(1,0,0, targetH) end
            end

            -- Expand once on first layout
            task.spawn(secExpand)

            secHdrBtn.MouseButton1Click:Connect(function()
                if secExpanded then task.spawn(secCollapse) else task.spawn(secExpand) end
            end)
            secHdrBtn.MouseEnter:Connect(function()
                Tween(secArrow,{TextTransparency=0},0.1)
            end)
            secHdrBtn.MouseLeave:Connect(function()
                Tween(secArrow,{TextTransparency=0.3},0.1)
            end)

            -- When content changes (elements added/removed), resize if expanded
            eLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if secExpanded then
                    task.wait()
                    local contentH = elems.AbsoluteSize.Y
                    secClip.Size = UDim2.new(1,0,0, contentH)
                    sec.Size     = UDim2.new(1,0,0, CLIP_TOP + contentH)
                end
            end)

            local Sec={}
            local function AE(f) f.LayoutOrder=#elems:GetChildren(); f.Parent=elems end

            -- Expose rename for the section header label
            function Sec:SetName(newName)
                secHdr.Text = newName
            end

