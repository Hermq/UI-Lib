                kbtn.BorderSizePixel=0; kbtn.ZIndex=15; kbtn.AutoButtonColor=false; kbtn.Parent=bg
                MakeCorner(kbtn,5)

                kbtn.MouseButton1Click:Connect(function() listening=true; kbtn.Text="..."; kbtn.TextColor3=theme.Accent end)
                AddConn(UserInputService.InputBegan:Connect(function(inp,gp)
                    if listening then
                        if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
                        listening=false
                        if inp.KeyCode==Enum.KeyCode.Escape then
                            cur=nil; if flag then NexusLib.Flags[flag]=nil end
                            kbtn.Text="None"; kbtn.TextColor3=theme.TextSecondary; return
                        end
                        if BLOCK[inp.KeyCode] then kbtn.Text=cur and cur.Name or "None"; kbtn.TextColor3=theme.TextSecondary; return end
                        cur=inp.KeyCode; if flag then NexusLib.Flags[flag]=cur end
                        kbtn.Text=cur.Name; kbtn.TextColor3=theme.TextSecondary
                    else
                        if not gp and inp.UserInputType==Enum.UserInputType.Keyboard and cur and inp.KeyCode==cur then cb() end
                    end
                end))

                local KB={}
                function KB:Set(k) cur=k; if flag then NexusLib.Flags[flag]=k end; kbtn.Text=k and k.Name or "None" end
                function KB:Get() return cur end
                function KB:SetCallback(f) cb=f end
                AE(row); return KB
            end

            -- DROPDOWN ───────────────────────────────────
            function Sec:AddDropdown(o)
                local n=o.Name or "Dropdown"; local items=o.Items or {}; local def=o.Default
                local flag=o.Flag; local cb=o.Callback or function()end
                local selected=def; local open=false
                if flag then NexusLib.Flags[flag]=selected end

                local row=MakeFrame({Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,32),Position=UDim2.new(0,8,0,2),BackgroundColor3=theme.ElementBg,ZIndex=14,Parent=row})
