                local selected=def; local open=false
                if flag then NexusLib.Flags[flag]=selected end

                -- Row: full section width, fixed height
                local ROW_H=36
                local row=MakeFrame({Size=UDim2.new(1,0,0,ROW_H),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,32),Position=UDim2.new(0,8,0,2),
