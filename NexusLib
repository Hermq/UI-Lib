-- ── Library Methods ───────────────────────────────────────
function NexusLib:Destroy()
    if self._gui and self._gui.Parent then self._gui:Destroy() end
    for _, c in pairs(self.Connections) do
        if typeof(c) == "RBXScriptConnection" then pcall(function() c:Disconnect() end) end
    end
    self.Connections = {}
    self.Flags  = {}
    self.Options = {}
    if getgenv then getgenv()._NexusLibInstance = nil end
end

function NexusLib:SetTheme(t)
    self._theme = type(t) == "string" and (self.Themes[t] or self.Themes.Dark) or t
end
NexusLib:SetTheme("Dark")

-- ── Notify ────────────────────────────────────────────────
function NexusLib:Notify(opts)
    local th       = self._theme
    local title    = opts.Title    or "Notice"
    local text     = opts.Text     or ""
    local duration = opts.Duration or 4
    local nType    = opts.Type     or "Info"

    local accentClr = th.Accent
    if nType == "Success" then accentClr = th.Success
    elseif nType == "Danger"  then accentClr = th.Danger
    elseif nType == "Warning" then accentClr = th.Warning end

    local offset = 0
    for _, ch in ipairs(gui:GetChildren()) do
        if ch.Name == "NexusNotif" then offset = offset + 76 end
    end

    local notif = MakeFrame({Name="NexusNotif",Size=UDim2.new(0,280,0,66),Position=UDim2.new(1,10,1,-(76+offset)),BackgroundColor3=th.SecondaryBg,ZIndex=200,Parent=gui})
    MakeCorner(notif,8)
    MakeStroke(notif, th.Border)
    local stripe = MakeFrame({Size=UDim2.new(0,3,1,0),BackgroundColor3=accentClr,ZIndex=201,Parent=notif})
    MakeCorner(stripe,3)
    MakeLabel({Size=UDim2.new(1,-20,0,20),Position=UDim2.new(0,12,0,8),Text=title,Font=Enum.Font.GothamBold,TextSize=13,TextColor3=th.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=202,Parent=notif})
    MakeLabel({Size=UDim2.new(1,-20,0,30),Position=UDim2.new(0,12,0,28),Text=text,TextSize=12,TextColor3=th.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=202,Parent=notif})
    local bar = MakeFrame({Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),BackgroundColor3=accentClr,ZIndex=202,Parent=notif})

    Tween(notif,{Position=UDim2.new(1,-290,1,-(76+offset))},0.3)
    Tween(bar,{Size=UDim2.new(0,0,0,2)},duration,Enum.EasingStyle.Linear)
    task.delay(duration,function()
        Tween(notif,{Position=UDim2.new(1,10,1,-(76+offset))},0.3)
        task.delay(0.35,function()
            notif:Destroy()
            if opts.Callback then opts.Callback() end
        end)
    end)
end

-- ── Prompt ────────────────────────────────────────────────
function NexusLib:Prompt(opts)
    local th      = self._theme
    local title   = opts.Title   or "Prompt"
    local text    = opts.Text    or ""
    local buttons = opts.Buttons or {OK = function() end}

    -- Dim overlay
    local overlay = MakeFrame({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0.5,ZIndex=500,Parent=gui})

    local W, H = 360, 140 + 36
    local modal = MakeFrame({Size=UDim2.new(0,W,0,H),Position=UDim2.new(0.5,-W/2,0.5,-H/2),BackgroundColor3=th.SecondaryBg,ZIndex=501,Parent=gui})
    MakeCorner(modal,10)
    MakeStroke(modal,th.Border)

    MakeLabel({Size=UDim2.new(1,-20,0,24),Position=UDim2.new(0,14,0,10),Text=title,Font=Enum.Font.GothamBold,TextSize=15,TextColor3=th.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=502,Parent=modal})
    MakeLabel({Size=UDim2.new(1,-20,0,60),Position=UDim2.new(0,14,0,38),Text=text,TextSize=13,TextColor3=th.TextSecondary,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=502,Parent=modal})

    local btnCount = 0
    for _ in pairs(buttons) do btnCount = btnCount + 1 end
    local btnW = math.min(120, (W-28) / btnCount - 6)
    local bx   = 14
    local by   = H - 44

    local function close()
        overlay:Destroy()
        modal:Destroy()
    end

    for label, cb in pairs(buttons) do
        local b = Instance.new("TextButton")
        b.Size=UDim2.new(0,btnW,0,32); b.Position=UDim2.new(0,bx,0,by)
        b.BackgroundColor3=th.ElementBg; b.Text=label; b.Font=Enum.Font.GothamBold
        b.TextSize=12; b.TextColor3=th.TextPrimary; b.BorderSizePixel=0
        b.ZIndex=503; b.AutoButtonColor=false; b.Parent=modal
        MakeCorner(b,6)
        b.MouseEnter:Connect(function() Tween(b,{BackgroundColor3=th.Accent},0.1) end)
        b.MouseLeave:Connect(function() Tween(b,{BackgroundColor3=th.ElementBg},0.1) end)
        b.MouseButton1Click:Connect(function() close() if cb then cb() end end)
        bx = bx + btnW + 8
    end
    return modal
end

-- ── CreateWindow ──────────────────────────────────────────
function NexusLib:CreateWindow(opts)
    local theme = opts.Theme
    if type(theme) == "string" then theme = self.Themes[theme] or self._theme
    elseif type(theme) ~= "table" then theme = self._theme end

    local winName    = opts.Name    or "Script"
    local winW       = (opts.Size and opts.Size.X) or 580
    local winH       = (opts.Size and opts.Size.Y) or 400
    local toggleKey  = opts.ToggleKey  -- optional: Enum.KeyCode.X
    local statusText = opts.Status  or ""
    local TBAR = 40
    local SBAR = 22   -- status bar height
    local TABW = 130

    -- Main frame
    local mainFrame = MakeFrame({Name="NexusWindow",Size=UDim2.new(0,winW,0,winH),Position=UDim2.new(0.5,-winW/2,0.5,-winH/2),BackgroundColor3=theme.Background,ZIndex=10,ClipsDescendants=false,Parent=gui})
    MakeCorner(mainFrame,10)

    -- Title bar
    local tbar = MakeFrame({Name="TitleBar",Size=UDim2.new(1,0,0,TBAR),BackgroundColor3=theme.SecondaryBg,ZIndex=11,Parent=mainFrame})
    MakeCorner(tbar,10)
    MakeFrame({Size=UDim2.new(1,0,0,12),Position=UDim2.new(0,0,1,-12),BackgroundColor3=theme.SecondaryBg,ZIndex=11,Parent=tbar})

    -- Accent line under titlebar
    MakeFrame({Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-1),BackgroundColor3=theme.Accent,ZIndex=12,Parent=tbar})

    MakeLabel({Size=UDim2.new(1,-90,1,0),Position=UDim2.new(0,14,0,0),Text=winName,Font=Enum.Font.GothamBold,TextSize=14,TextColor3=theme.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,Parent=tbar})

    local minBtn = Instance.new("TextButton")
    minBtn.Size=UDim2.new(0,28,0,28); minBtn.Position=UDim2.new(1,-62,0.5,-14)
    minBtn.BackgroundColor3=theme.TertiaryBg; minBtn.Text="−"; minBtn.Font=Enum.Font.GothamBold
    minBtn.TextSize=18; minBtn.TextColor3=theme.TextSecondary; minBtn.BorderSizePixel=0
    minBtn.ZIndex=13; minBtn.AutoButtonColor=false; minBtn.Parent=tbar
    MakeCorner(minBtn,6)

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,28,0,28); closeBtn.Position=UDim2.new(1,-30,0.5,-14)
    closeBtn.BackgroundColor3=Color3.fromRGB(180,50,50); closeBtn.Text="×"; closeBtn.Font=Enum.Font.GothamBold
    closeBtn.TextSize=20; closeBtn.TextColor3=Color3.fromRGB(255,255,255); closeBtn.BorderSizePixel=0
    closeBtn.ZIndex=13; closeBtn.AutoButtonColor=false; closeBtn.Parent=tbar
    MakeCorner(closeBtn,6)

    minBtn.MouseEnter:Connect(function() Tween(minBtn,{BackgroundColor3=theme.ElementHover},0.1) end)
    minBtn.MouseLeave:Connect(function() Tween(minBtn,{BackgroundColor3=theme.TertiaryBg},0.1) end)
    closeBtn.MouseEnter:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(220,70,70)},0.1) end)
    closeBtn.MouseLeave:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(180,50,50)},0.1) end)

    -- Body
    local bodyH = winH - TBAR - SBAR
    local body = MakeFrame({Name="Body",Size=UDim2.new(1,0,0,bodyH),Position=UDim2.new(0,0,0,TBAR),BackgroundColor3=theme.Background,ZIndex=10,ClipsDescendants=true,Parent=mainFrame})

    -- Status bar
    local sbar = MakeFrame({Name="StatusBar",Size=UDim2.new(1,0,0,SBAR),Position=UDim2.new(0,0,1,-SBAR),BackgroundColor3=theme.SecondaryBg,ZIndex=11,Parent=mainFrame})
    local sbarLine = MakeFrame({Size=UDim2.new(1,0,0,1),BackgroundColor3=theme.Border,ZIndex=12,Parent=sbar})
    local sbarLabel = MakeLabel({Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,10,0,0),Text=statusText,TextSize=11,TextColor3=theme.TextDim,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,Parent=sbar})

    -- Sidebar
    local sidebar = MakeFrame({Name="Sidebar",Size=UDim2.new(0,TABW,1,0),BackgroundColor3=theme.SecondaryBg,ZIndex=11,Parent=body})
    local tabList = Instance.new("UIListLayout"); tabList.SortOrder=Enum.SortOrder.LayoutOrder; tabList.Padding=UDim.new(0,3); tabList.Parent=sidebar
    local tabPad  = Instance.new("UIPadding"); tabPad.PaddingTop=UDim.new(0,8); tabPad.PaddingLeft=UDim.new(0,6); tabPad.PaddingRight=UDim.new(0,6); tabPad.Parent=sidebar

    -- Page holder
    local pageHolder = MakeFrame({Name="Pages",Size=UDim2.new(1,-TABW,1,0),Position=UDim2.new(0,TABW,0,0),BackgroundTransparency=1,ZIndex=10,ClipsDescendants=true,Parent=body})

    local Win = {_frame=mainFrame,_theme=theme,_tabs={},_minimized=false}

    -- Dragging
    local dragging,dragStart,startPos=false,nil,nil
    AddConn(tbar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; dragStart=i.Position; startPos=mainFrame.Position end
    end))
    AddConn(UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-dragStart
            mainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end))
    AddConn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end))

    -- Minimize
    minBtn.MouseButton1Click:Connect(function()
        Win._minimized = not Win._minimized
        if Win._minimized then
            body.Visible=false; sbar.Visible=false
            Tween(mainFrame,{Size=UDim2.new(0,winW,0,TBAR)},0.2)
        else
            Tween(mainFrame,{Size=UDim2.new(0,winW,0,winH)},0.2)
            task.delay(0.15,function() body.Visible=true; sbar.Visible=true end)
        end
    end)

    closeBtn.MouseButton1Click:Connect(function() mainFrame:Destroy() end)

    -- Toggle keybind
    if toggleKey then
        AddConn(UserInputService.InputBegan:Connect(function(i,gp)
            if not gp and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==toggleKey then
                mainFrame.Visible = not mainFrame.Visible
            end
        end))
    end

    function Win:ToggleVisible()
        if mainFrame and mainFrame.Parent then mainFrame.Visible = not mainFrame.Visible end
    end

    function Win:SetStatus(text)
        sbarLabel.Text = text or ""
    end

    function Win:Destroy()
        if mainFrame and mainFrame.Parent then mainFrame:Destroy() end
    end

    function Win:SetTheme(t)
        -- Runtime theme switching (updates accent line and status bar)
        if type(t) == "string" then theme = NexusLib.Themes[t] or theme end
    end

    -- ── AddTab ───────────────────────────────────────────
    function Win:AddTab(opts)
        local tName = opts.Name or "Tab"
        local tIcon = opts.Icon -- optional rbxassetid

        local tbtn = Instance.new("TextButton")
        tbtn.Name="TBtn_"..tName; tbtn.Size=UDim2.new(1,0,0,32)
        tbtn.BackgroundColor3=theme.TertiaryBg; tbtn.BackgroundTransparency=1
        tbtn.BorderSizePixel=0; tbtn.LayoutOrder=#Win._tabs+1
        tbtn.ZIndex=12; tbtn.AutoButtonColor=false; tbtn.Parent=sidebar
        MakeCorner(tbtn,6)

        if tIcon then
            local img = Instance.new("ImageLabel")
            img.Size=UDim2.new(0,16,0,16); img.Position=UDim2.new(0,8,0.5,-8)
            img.BackgroundTransparency=1; img.Image=tIcon; img.ZIndex=13; img.Parent=tbtn
            local lbl = MakeLabel({Size=UDim2.new(1,-32,1,0),Position=UDim2.new(0,30,0,0),Text=tName,Font=Enum.Font.Gotham,TextSize=13,TextColor3=theme.TextDim,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=13,Parent=tbtn})
            tbtn:GetPropertyChangedSignal("TextColor3"):Connect(function() lbl.TextColor3=tbtn.TextColor3 end)
        else
            tbtn.Text=tName; tbtn.Font=Enum.Font.Gotham; tbtn.TextSize=13; tbtn.TextColor3=theme.TextDim
        end

        -- Left accent bar for active tab
        local accentBar = MakeFrame({Size=UDim2.new(0,3,0,18),Position=UDim2.new(0,0,0.5,-9),BackgroundColor3=theme.Accent,ZIndex=13,Parent=tbtn})
        accentBar.Visible=false
        MakeCorner(accentBar,2)

        local page = Instance.new("ScrollingFrame")
        page.Name="Pg_"..tName; page.Size=UDim2.new(1,0,1,0)
        page.BackgroundTransparency=1; page.BorderSizePixel=0
        page.ScrollBarThickness=3; page.ScrollBarImageColor3=theme.ScrollBar
        page.CanvasSize=UDim2.new(0,0,0,0); page.AutomaticCanvasSize=Enum.AutomaticSize.Y
        page.Visible=false; page.ZIndex=11; page.ClipsDescendants=true; page.Parent=pageHolder
        local pgLL=Instance.new("UIListLayout"); pgLL.SortOrder=Enum.SortOrder.LayoutOrder; pgLL.Padding=UDim.new(0,6); pgLL.Parent=page
        local pgPd=Instance.new("UIPadding"); pgPd.PaddingTop=UDim.new(0,8); pgPd.PaddingLeft=UDim.new(0,8); pgPd.PaddingRight=UDim.new(0,8); pgPd.PaddingBottom=UDim.new(0,8); pgPd.Parent=page

        local Tab={_page=page,_btn=tbtn}

        local function Sel()
            for _,t in ipairs(Win._tabs) do
                t._page.Visible=false
                Tween(t._btn,{BackgroundTransparency=1,TextColor3=theme.TextDim},0.1)
                local ab=t._btn:FindFirstChild("AccentBar") -- find by name if we stored it
                if ab then ab.Visible=false end
            end
            page.Visible=true
            accentBar.Visible=true
            tbtn.BackgroundTransparency=0; tbtn.BackgroundColor3=theme.ElementBg
            Tween(tbtn,{TextColor3=theme.TextPrimary},0.1)
        end
        accentBar.Name="AccentBar"
        tbtn.MouseButton1Click:Connect(Sel)
        table.insert(Win._tabs,Tab)
        if #Win._tabs==1 then Sel() end

        -- ── AddSection ───────────────────────────────────
        function Tab:AddSection(opts)
            local sName = opts.Name or "Section"
            local sec=Instance.new("Frame")
            sec.Name="S_"..sName; sec.Size=UDim2.new(1,0,0,0); sec.AutomaticSize=Enum.AutomaticSize.Y
            sec.BackgroundColor3=theme.SecondaryBg; sec.BorderSizePixel=0
            sec.LayoutOrder=#page:GetChildren(); sec.ZIndex=12; sec.ClipsDescendants=false; sec.Parent=page
            MakeCorner(sec,8)

            -- Section header
            MakeLabel({Size=UDim2.new(1,-12,0,24),Position=UDim2.new(0,10,0,2),Text=sName,Font=Enum.Font.GothamBold,TextSize=12,TextColor3=theme.Accent,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=13,Parent=sec})
