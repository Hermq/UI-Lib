-- The accordion factory itself
function NexusLib._makeAccordion(parentContainer, theme, name, depth, parentRemeasure)
    depth           = depth or 0
    parentRemeasure = parentRemeasure or function() end

    local HDR_H   = math.max(36 - depth * 3, 28)
    local HDR_COL = depth == 0 and theme.SecondaryBg or theme.TertiaryBg
    local BAR_W   = math.max(4 - depth, 2)
    local FONT    = depth == 0 and Enum.Font.GothamBold or Enum.Font.Gotham
    local FSIZE   = math.max(13 - depth, 11)
    local PAD_V   = math.max(7 - depth * 2, 3)
    local PAD_H   = math.max(6 - depth, 2)

    local row = MakeFrame({
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex            = 10 + depth,
        Parent            = parentContainer,
    })
    row.LayoutOrder = #parentContainer:GetChildren()

    local header = Instance.new("TextButton")
    header.Size = UDim2.new(1, 0, 0, HDR_H)
    header.BackgroundColor3 = HDR_COL
    header.Text = ""; header.BorderSizePixel = 0
    header.AutoButtonColor = false; header.ZIndex = 11 + depth
    header.Parent = row
    MakeCorner(header, math.max(8 - depth * 2, 4))

    local acBar = MakeFrame({
        Size             = UDim2.new(0, BAR_W, 1, -math.floor(HDR_H * 0.4)),
        Position         = UDim2.new(0, 0, 0, math.floor(HDR_H * 0.2)),
        BackgroundColor3 = theme.Accent,
        ZIndex           = 12 + depth, Parent = header,
    })
    MakeCorner(acBar, 3)

    local nameLbl = MakeLabel({
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, BAR_W + 8, 0, 0),
        Text = name, Font = FONT, TextSize = FSIZE,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 12 + depth, Parent = header,
    })
    nameLbl.TextColor3 = depth == 0 and theme.TextPrimary or theme.TextSecondary

    local arrow = MakeLabel({
        Size = UDim2.new(0, 22, 1, 0), Position = UDim2.new(1, -24, 0, 0),
        Text = "▸", Font = Enum.Font.GothamBold,
        TextSize = math.max(13 - depth, 10),
        ZIndex = 12 + depth, Parent = header,
    })
    arrow.TextColor3 = theme.TextDim

    local clip = MakeFrame({
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, HDR_H + 2),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 10 + depth, Parent = row,
    })

    local inner = MakeFrame({
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex = 10 + depth, Parent = clip,
    })

    local ll = Instance.new("UIListLayout")
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding   = UDim.new(0, math.max(5 - depth, 2))
    ll.Parent    = inner

    local pd = Instance.new("UIPadding")
    pd.PaddingTop    = UDim.new(0, PAD_V)
    pd.PaddingBottom = UDim.new(0, PAD_V)
    pd.PaddingLeft   = UDim.new(0, PAD_H)
    pd.PaddingRight  = UDim.new(0, PAD_H)
    pd.Parent        = inner

    local expanded = false
    local Acc = {}

    local function remeasure()
        if not expanded then return end
        task.wait()
        local h = inner.AbsoluteSize.Y
        Tween(clip, {Size = UDim2.new(1, 0, 0, h)}, 0.14)
        task.delay(0.16, parentRemeasure)
    end

    local function doExpand()
        expanded = true
        task.wait()
        local h = inner.AbsoluteSize.Y
        Tween(clip,   {Size = UDim2.new(1, 0, 0, h)}, 0.22)
        Tween(arrow,  {Rotation = 90}, 0.18)
        Tween(header, {BackgroundColor3 = theme.ElementHover}, 0.12)
        acBar.BackgroundColor3 = theme.AccentBar
        task.delay(0.24, parentRemeasure)
    end

    local function doCollapse()
        expanded = false
        Tween(clip,   {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
        Tween(arrow,  {Rotation = 0}, 0.18)
        Tween(header, {BackgroundColor3 = HDR_COL}, 0.12)
        acBar.BackgroundColor3 = theme.Accent
        task.delay(0.20, parentRemeasure)
    end

    header.MouseButton1Click:Connect(function()
        if expanded then doCollapse() else task.spawn(doExpand) end
    end)
    header.MouseEnter:Connect(function()
        if not expanded then Tween(header,{BackgroundColor3=theme.ElementHover},0.1) end
    end)
    header.MouseLeave:Connect(function()
        if not expanded then Tween(header,{BackgroundColor3=HDR_COL},0.1) end
    end)

    _attachAccordionElements(Acc, inner, theme, remeasure, depth)

    -- Override so nested accordions pass correct depth + remeasure
    function Acc:AddAccordion(o)
        return NexusLib._makeAccordion(inner, theme, o.Name or "Group", depth + 1, remeasure)
    end

    Acc._remeasure = remeasure
    return Acc
end

-- ── CreateWindow ──────────────────────────────────────────
function NexusLib:CreateWindow(opts)
    local theme=opts.Theme
    if type(theme)=="string" then theme=self.Themes[theme] or self._theme
    elseif type(theme)~="table" then theme=self._theme end

    local winName   = opts.Name      or "Script"
    local winW      = (opts.Size and opts.Size.X) or 580
    local winH      = (opts.Size and opts.Size.Y) or 400
    local toggleKey = opts.ToggleKey
    local statusTxt = opts.Status    or ""
    local bgUrl     = opts.CustomBackground
    local TBAR,SBAR,TABW = 40,22,130

    local _refs={}
    local function R(obj,prop,key)
        table.insert(_refs,{obj,prop,key})
        pcall(function() obj[prop]=theme[key] end)
    end

    local mainFrame=MakeFrame({Name="NexusWindow",
        Size=UDim2.new(0,winW*0.96,0,winH*0.96),
        Position=UDim2.new(0.5,-winW*0.96/2,0.5,-winH*0.96/2),
        ZIndex=10,ClipsDescendants=false,BackgroundTransparency=1,Parent=gui})
    R(mainFrame,"BackgroundColor3","Background"); MakeCorner(mainFrame,10)

    local bgImage = nil
    if bgUrl and type(bgUrl)=="string" then
        bgImage = Instance.new("ImageLabel")
        bgImage.Size=UDim2.new(1,0,1,0); bgImage.BackgroundTransparency=1
        bgImage.Image=bgUrl; bgImage.ImageTransparency=0.65
        bgImage.ScaleType=Enum.ScaleType.Crop; bgImage.ZIndex=10; bgImage.Parent=mainFrame
        MakeCorner(bgImage,10)
    end

    TweenSpring(mainFrame,{
        Size=UDim2.new(0,winW,0,winH),
        Position=UDim2.new(0.5,-winW/2,0.5,-winH/2),
        BackgroundTransparency=0
    },0.45)

    local tbar=MakeFrame({Name="TitleBar",Size=UDim2.new(1,0,0,TBAR),ZIndex=11,Parent=mainFrame})
    R(tbar,"BackgroundColor3","SecondaryBg"); MakeCorner(tbar,10)
    local tbarPatch=MakeFrame({Size=UDim2.new(1,0,0,12),Position=UDim2.new(0,0,1,-12),ZIndex=11,Parent=tbar})
    R(tbarPatch,"BackgroundColor3","SecondaryBg")
    local accentLine=MakeFrame({Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-1),ZIndex=12,Parent=tbar})
    R(accentLine,"BackgroundColor3","Accent")
    local statusDot=MakeFrame({Size=UDim2.new(0,7,0,7),Position=UDim2.new(0,10,0.5,-3),ZIndex=13,Parent=tbar})
    R(statusDot,"BackgroundColor3","TextDim"); MakeCorner(statusDot,4)
    local titleLbl=MakeLabel({Size=UDim2.new(1,-90,1,0),Position=UDim2.new(0,24,0,0),
        Text=winName,Font=Enum.Font.GothamBold,TextSize=14,ZIndex=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=tbar})
    R(titleLbl,"TextColor3","TextPrimary")

    local minBtn=Instance.new("TextButton")
    minBtn.Size=UDim2.new(0,28,0,28); minBtn.Position=UDim2.new(1,-62,0.5,-14)
    minBtn.Text="−"; minBtn.Font=Enum.Font.GothamBold; minBtn.TextSize=18
    minBtn.BorderSizePixel=0; minBtn.ZIndex=13; minBtn.AutoButtonColor=false; minBtn.Parent=tbar
    R(minBtn,"BackgroundColor3","TertiaryBg"); R(minBtn,"TextColor3","TextSecondary"); MakeCorner(minBtn,6)

    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,28,0,28); closeBtn.Position=UDim2.new(1,-30,0.5,-14)
    closeBtn.BackgroundColor3=Color3.fromRGB(180,50,50); closeBtn.Text="×"
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.TextSize=20
    closeBtn.TextColor3=Color3.fromRGB(255,255,255); closeBtn.BorderSizePixel=0
    closeBtn.ZIndex=13; closeBtn.AutoButtonColor=false; closeBtn.Parent=tbar; MakeCorner(closeBtn,6)

    minBtn.MouseEnter:Connect(function() Tween(minBtn,{BackgroundColor3=theme.ElementHover},0.1) end)
    minBtn.MouseLeave:Connect(function() Tween(minBtn,{BackgroundColor3=theme.TertiaryBg},0.1) end)
    closeBtn.MouseEnter:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(220,70,70)},0.1) end)
    closeBtn.MouseLeave:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(180,50,50)},0.1) end)
    AddPressScale(minBtn); AddPressScale(closeBtn)

    local body=MakeFrame({Name="Body",Size=UDim2.new(1,0,0,winH-TBAR-SBAR),
        Position=UDim2.new(0,0,0,TBAR),ZIndex=10,ClipsDescendants=true,Parent=mainFrame})
    R(body,"BackgroundColor3","Background")

    local sbar=MakeFrame({Name="StatusBar",Size=UDim2.new(1,0,0,SBAR),
        Position=UDim2.new(0,0,1,-SBAR),ZIndex=11,Parent=mainFrame})
    R(sbar,"BackgroundColor3","SecondaryBg")
    local sbarBorder=MakeFrame({Size=UDim2.new(1,0,0,1),ZIndex=12,Parent=sbar})
    R(sbarBorder,"BackgroundColor3","Border")
    local sbarLbl=MakeLabel({Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,10,0,0),
        Text=statusTxt,TextSize=11,ZIndex=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=sbar})
    R(sbarLbl,"TextColor3","TextDim")

    local sidebar=MakeFrame({Name="Sidebar",Size=UDim2.new(0,TABW,1,0),ZIndex=11,Parent=body})
    R(sidebar,"BackgroundColor3","SecondaryBg")
    -- FIX: If custom background, make sidebar slightly transparent
    if bgUrl then sidebar.BackgroundTransparency = 0.15 end
    
    local tabLL=Instance.new("UIListLayout"); tabLL.SortOrder=Enum.SortOrder.LayoutOrder
    tabLL.Padding=UDim.new(0,3); tabLL.Parent=sidebar
    local tabPd=Instance.new("UIPadding"); tabPd.PaddingTop=UDim.new(0,8)
    tabPd.PaddingLeft=UDim.new(0,6); tabPd.PaddingRight=UDim.new(0,6); tabPd.Parent=sidebar

    local pageHolder=MakeFrame({Name="Pages",Size=UDim2.new(1,-TABW,1,0),
        Position=UDim2.new(0,TABW,0,0),BackgroundTransparency=1,
        ZIndex=10,ClipsDescendants=true,Parent=body})

    local Win={_frame=mainFrame,_theme=theme,_tabs={},_minimized=false,_refs=_refs}

    -- Dragging
    local dragging,dragStart,startPos=false,nil,nil
    AddConn(tbar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=i.Position; startPos=mainFrame.Position
        end
    end))
    AddConn(UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-dragStart
            mainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,
                startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end))
    AddConn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end))

    -- FIXED Minimize
    minBtn.MouseButton1Click:Connect(function()
        Win._minimized = not Win._minimized
        if Win._minimized then
            TweenSine(body, {BackgroundTransparency=1}, 0.20)
            task.delay(0.21, function()
                body.Visible = false; sbar.Visible = false
                body.BackgroundTransparency = 0
                Tween(mainFrame, {Size=UDim2.new(0,winW,0,TBAR)}, 0.22, Enum.EasingStyle.Quart)
            end)
        else
            Tween(mainFrame, {Size=UDim2.new(0,winW,0,winH)}, 0.25, Enum.EasingStyle.Quart)
            task.delay(0.26, function()
                body.Visible = true; sbar.Visible = true
                body.BackgroundTransparency = 1
                TweenSine(body, {BackgroundTransparency=0}, 0.20)
            end)
        end
    end)

    -- FIXED Close
    closeBtn.MouseButton1Click:Connect(function()
        TweenSine(mainFrame, {
            Size=UDim2.new(0,winW*0.88,0,winH*0.88),
            BackgroundTransparency=1,
        }, 0.28)
        task.delay(0.30, function() mainFrame:Destroy() end)
    end)

    if toggleKey then
        AddConn(UserInputService.InputBegan:Connect(function(i,gp)
            if NexusLib._listening then return end
            if not gp and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==toggleKey then
                Win:ToggleVisible()
            end
        end))
    end

    -- ── Win methods ──────────────────────────────────────
    function Win:ToggleVisible()
        if not mainFrame or not mainFrame.Parent then return end
        if mainFrame.Visible then
            TweenSine(mainFrame,{Position=UDim2.new(
                mainFrame.Position.X.Scale,mainFrame.Position.X.Offset,
                mainFrame.Position.Y.Scale,mainFrame.Position.Y.Offset+8),
                BackgroundTransparency=1},0.18)
            task.delay(0.20,function()
                mainFrame.Visible=false; mainFrame.BackgroundTransparency=0
            end)
        else
            mainFrame.Position=UDim2.new(
                mainFrame.Position.X.Scale,mainFrame.Position.X.Offset,
                mainFrame.Position.Y.Scale,mainFrame.Position.Y.Offset+8)
            mainFrame.Visible=true; mainFrame.BackgroundTransparency=1
            TweenSine(mainFrame,{Position=UDim2.new(
                mainFrame.Position.X.Scale,mainFrame.Position.X.Offset,
                mainFrame.Position.Y.Scale,mainFrame.Position.Y.Offset-8),
                BackgroundTransparency=0},0.22)
        end
    end

    function Win:SetStatus(text,dotColor)
        sbarLbl.Text=text or ""
        if dotColor then Tween(statusDot,{BackgroundColor3=dotColor},0.2) end
    end

    function Win:SetTheme(t)
        local nt=type(t)=="string" and NexusLib.Themes[t] or t
        if not nt then return end
        theme=nt; Win._theme=nt
        for _,r in ipairs(_refs) do
            pcall(function()
                r[1][r[2]]=theme[r[3]]
                if r[2]=="BackgroundColor3" then
                    local a=theme[r[3].."_alpha"]
                    if a then r[1].BackgroundTransparency=1-a end
                end
            end)
        end
    end

    function Win:SetBackground(url)
        url = url or ""
        url = url:match("^%s*(.-)%s*$")
        if url ~= "" then
            if url:match("^%d+$") then url = "rbxassetid://"..url end
            if url:match("^https?://") then
                warn("[NexusLib] SetBackground: external URLs blocked by Roblox. Use rbxassetid://."); url=""
            end
        end
        if bgImage then bgImage.Image = url
        elseif url ~= "" then
            bgImage=Instance.new("ImageLabel")
            bgImage.Size=UDim2.new(1,0,1,0); bgImage.BackgroundTransparency=1
            bgImage.Image=url; bgImage.ImageTransparency=0.65
            bgImage.ScaleType=Enum.ScaleType.Crop; bgImage.ZIndex=10
            bgImage.Parent=mainFrame; MakeCorner(bgImage,10)
        end
    end

    function Win:Destroy()
        if mainFrame and mainFrame.Parent then mainFrame:Destroy() end
    end

    -- ── AddTab ───────────────────────────────────────────
    function Win:AddTab(opts)
        local tName=opts.Name or "Tab"
        local tIcon=opts.Icon

        local tbtn=Instance.new("TextButton")
        tbtn.Name="TBtn_"..tName; tbtn.Size=UDim2.new(1,0,0,34)
        tbtn.BackgroundTransparency=1; tbtn.BorderSizePixel=0
        tbtn.LayoutOrder=#Win._tabs+1; tbtn.ZIndex=12
        tbtn.AutoButtonColor=false; tbtn.Parent=sidebar
        MakeCorner(tbtn,6)

        if tIcon then
            local img=Instance.new("ImageLabel")
            img.Size=UDim2.new(0,16,0,16); img.Position=UDim2.new(0,10,0.5,-8)
            img.BackgroundTransparency=1; img.Image=tIcon; img.ZIndex=13; img.Parent=tbtn
            local lbl=MakeLabel({Size=UDim2.new(1,-34,1,0),Position=UDim2.new(0,32,0,0),
                Text=tName,Font=Enum.Font.Gotham,TextSize=13,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=13,Parent=tbtn})
            R(lbl,"TextColor3","TextDim")
        else
            tbtn.Text=tName; tbtn.Font=Enum.Font.Gotham; tbtn.TextSize=13
            R(tbtn,"TextColor3","TextDim")
        end

        local acBar=MakeFrame({Size=UDim2.new(0,4,0,20),Position=UDim2.new(0,0,0.5,-10),
            ZIndex=13,Visible=false,Parent=tbtn})
        acBar.Name="AccentBar"; R(acBar,"BackgroundColor3","AccentBar"); MakeCorner(acBar,3)

        local cg = Instance.new("CanvasGroup")
        cg.Size=UDim2.new(1,0,1,0); cg.BackgroundTransparency=1
        cg.GroupTransparency=1; cg.BorderSizePixel=0
        cg.Visible=false; cg.ZIndex=11; cg.Parent=pageHolder

        local page=Instance.new("ScrollingFrame")
        page.Name="Pg_"..tName; page.Size=UDim2.new(1,0,1,0)
        page.BackgroundTransparency=1; page.BorderSizePixel=0
        page.ScrollBarThickness=3
        page.CanvasSize=UDim2.new(0,0,0,0); page.AutomaticCanvasSize=Enum.AutomaticSize.Y
        page.ZIndex=11; page.ClipsDescendants=true; page.Parent=cg
        R(page,"ScrollBarImageColor3","ScrollBar")
        local pgLL=Instance.new("UIListLayout"); pgLL.SortOrder=Enum.SortOrder.LayoutOrder
        pgLL.Padding=UDim.new(0,6); pgLL.Parent=page
        local pgPd=Instance.new("UIPadding")
        pgPd.PaddingTop=UDim.new(0,8); pgPd.PaddingLeft=UDim.new(0,8)
        pgPd.PaddingRight=UDim.new(0,8); pgPd.PaddingBottom=UDim.new(0,8); pgPd.Parent=page

        local Tab={_page=page,_cg=cg,_btn=tbtn,_acBar=acBar}

        local function Sel()
            for _,t in ipairs(Win._tabs) do
                if t._cg.Visible then
                    TweenSine(t._cg,{Position=UDim2.new(-0.08,0,0,0)},0.18)
                    Tween(t._cg,{GroupTransparency=1},0.18)
                    task.delay(0.19,function()
                        t._cg.Visible=false
                        t._cg.Position=UDim2.new(0,0,0,0)
                        t._cg.GroupTransparency=1
                    end)
                end
                t._acBar.Visible=false
                Tween(t._btn,{BackgroundTransparency=1},0.1)
                if t._btn.Text~="" then Tween(t._btn,{TextColor3=theme.TextDim},0.1) end
            end

            cg.Position=UDim2.new(0.06,0,0,0)
            cg.GroupTransparency=1; cg.Visible=true
            TweenSine(cg,{Position=UDim2.new(0,0,0,0)},0.22)
            Tween(cg,{GroupTransparency=0},0.22)

            task.spawn(function()
                local idx=0
                for _,child in ipairs(page:GetChildren()) do
                    if child:IsA("Frame") then
                        idx=idx+1; child.BackgroundTransparency=1
                        task.delay(idx*0.04,function()
                            TweenSine(child,{BackgroundTransparency=0},0.2)
                        end)
                    end
                end
            end)

            acBar.Visible=true; tbtn.BackgroundTransparency=0
            pcall(function() tbtn.BackgroundColor3=theme.ElementBg end)
            if tbtn.Text~="" then Tween(tbtn,{TextColor3=theme.TextPrimary},0.1) end
        end

        tbtn.MouseButton1Click:Connect(Sel)
        tbtn.MouseEnter:Connect(function()
            if tbtn.BackgroundTransparency~=0 then Tween(tbtn,{BackgroundTransparency=0.6},0.1) end
        end)
        tbtn.MouseLeave:Connect(function()
            if tbtn.BackgroundTransparency~=0 then Tween(tbtn,{BackgroundTransparency=1},0.1) end
        end)

        table.insert(Win._tabs,Tab)
        if #Win._tabs==1 then Sel() end

        -- ── AddSection (full original with every element type) ─
        function Tab:AddSection(sopts)
            local sName=sopts.Name or "Section"
            local sec=Instance.new("Frame")
            sec.Name="S_"..sName; sec.Size=UDim2.new(1,0,0,0)
            sec.AutomaticSize=Enum.AutomaticSize.Y; sec.BorderSizePixel=0
            sec.LayoutOrder=#page:GetChildren(); sec.ZIndex=12
            sec.ClipsDescendants=false; sec.Parent=page
            R(sec,"BackgroundColor3","SecondaryBg"); MakeCorner(sec,8)

            local secHdr=MakeLabel({Size=UDim2.new(1,-12,0,24),Position=UDim2.new(0,10,0,2),
                Text=sName,Font=Enum.Font.GothamBold,TextSize=12,
                TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,
                ZIndex=13,Parent=sec})
            R(secHdr,"TextColor3","TextPrimary")

            local cnt=MakeFrame({Name="Content",Size=UDim2.new(1,0,0,0),
                Position=UDim2.new(0,0,0,26),BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,ZIndex=12,Parent=sec})
            local cntLL=Instance.new("UIListLayout")
            cntLL.SortOrder=Enum.SortOrder.LayoutOrder; cntLL.Padding=UDim.new(0,4)
            cntLL.Parent=cnt

            local function onAdd() 
                -- Trigger layout update
                sec.Size = UDim2.new(1,0,0,0) 
            end

            _attachAccordionElements(sec, cnt, theme, onAdd, 0)

            return sec
        end

        return Tab
    end

    return Win
end

return NexusLib
