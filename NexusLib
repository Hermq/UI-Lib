        local Sli={}
        local function SV(v,fire)
            v=math.clamp(math.floor(v+0.5),smin,smax)
            val=v; if flag then NexusLib.Flags[flag]=v end
            local p=(smax>smin) and (v-smin)/(smax-smin) or 0
            fill.Size=UDim2.new(p,0,1,0)
            thumb.Position=UDim2.new(p,-6,0.5,-6)
