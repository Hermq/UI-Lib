                dbtn.TextSize=12; dbtn.TextColor3=theme.TextSecondary; dbtn.BorderSizePixel=0
                dbtn.ZIndex=15; dbtn.AutoButtonColor=false; dbtn.Parent=bg; dbtn.ClipsDescendants=true
                MakeCorner(dbtn,5)
                -- Arrow
                local arrow=MakeLabel({Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-18,0,0),Text="▾",TextSize=12,TextColor3=theme.TextDim,ZIndex=16,Parent=dbtn})

                -- Dropdown list (overlay, high ZIndex)
                local listFrame=MakeFrame({Size=UDim2.new(0,0,0,0),BackgroundColor3=theme.TertiaryBg,ZIndex=50,Visible=false})
                listFrame.Parent=gui  -- parent to gui so it floats above everything
                MakeCorner(listFrame,6)
                MakeStroke(listFrame,theme.Border)
                local listLayout=Instance.new("UIListLayout"); listLayout.SortOrder=Enum.SortOrder.LayoutOrder; listLayout.Parent=listFrame
                local listPad=Instance.new("UIPadding"); listPad.PaddingTop=UDim.new(0,4); listPad.PaddingBottom=UDim.new(0,4); listPad.Parent=listFrame

                local Drop={}

                local function Populate()
                    for _,c in pairs(listFrame:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _,item in ipairs(items) do
                        local ib=Instance.new("TextButton")
                        ib.Size=UDim2.new(1,0,0,28); ib.BackgroundColor3=theme.TertiaryBg
                        ib.Text=" "..tostring(item); ib.Font=Enum.Font.Gotham; ib.TextSize=12
                        ib.TextColor3=(item==selected) and theme.Accent or theme.TextSecondary
                        ib.TextXAlignment=Enum.TextXAlignment.Left; ib.BorderSizePixel=0
                        ib.ZIndex=51; ib.AutoButtonColor=false; ib.Parent=listFrame
                        ib.MouseEnter:Connect(function() Tween(ib,{BackgroundColor3=theme.ElementHover},0.08) end)
                        ib.MouseLeave:Connect(function() Tween(ib,{BackgroundColor3=theme.TertiaryBg},0.08) end)
                        ib.MouseButton1Click:Connect(function()
                            selected=item; dbtn.Text=tostring(item)
                            if flag then NexusLib.Flags[flag]=item end
                            cb(item); Drop:Close()
                        end)
                    end
                end

                function Drop:Open()
                    open=true
                    Populate()
                    local absPos=dbtn.AbsolutePosition; local absSize=dbtn.AbsoluteSize
                    local lh=math.min(#items,6)*28+8
                    local lw=absSize.X
                    listFrame.Size=UDim2.new(0,lw,0,lh)
                    listFrame.Position=UDim2.new(0,absPos.X,0,absPos.Y+absSize.Y+2)
                    listFrame.Visible=true
                    Tween(arrow,{Rotation=180},0.15)
                end

                function Drop:Close()
                    open=false; listFrame.Visible=false
                    Tween(arrow,{Rotation=0},0.15)
                end

                function Drop:Set(v)
                    selected=v; dbtn.Text=tostring(v)
                    if flag then NexusLib.Flags[flag]=v end
                end

                function Drop:Get() return selected end
                function Drop:SetItems(i) items=i end
                function Drop:SetCallback(f) cb=f end

                dbtn.MouseButton1Click:Connect(function()
                    if open then Drop:Close() else Drop:Open() end
                end)

                -- Close when clicking elsewhere
                AddConn(UserInputService.InputBegan:Connect(function(i)
                    if open and i.UserInputType==Enum.UserInputType.MouseButton1 then
                        task.defer(function()
                            if not dbtn:IsDescendantOf(gui) then return end
                            local mp=UserInputService:GetMouseLocation()
                            local lp=listFrame.AbsolutePosition; local ls=listFrame.AbsoluteSize
                            if mp.X<lp.X or mp.X>lp.X+ls.X or mp.Y<lp.Y or mp.Y>lp.Y+ls.Y then
                                Drop:Close()
                            end
                        end)
                    end
                end))

                AE(row); return Drop
            end

