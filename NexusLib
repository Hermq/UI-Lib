            dLbl.TextColor3 = theme.TextSecondary
            dLbl.TextXAlignment = Enum.TextXAlignment.Left
            dLbl.TextWrapped = true
            dLbl.Visible = false
            dLbl.TextTransparency = 1
            dLbl.ZIndex = 24
            dLbl.Parent = bg
            
            local arrow = Instance.new("ImageButton")
