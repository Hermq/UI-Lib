-- ── Helpers ───────────────────────────────────────────────
local function Tween(obj, props, t, style, dir)
    pcall(function()
        TweenService:Create(obj, TweenInfo.new(t or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props):Play()
    end)
end

local function AddConn(conn)
    table.insert(NexusLib.Connections, conn)
    return conn
end

local function MakeCorner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, col, thick)
    local s = Instance.new("UIStroke")
    s.Color = col or Color3.fromRGB(60,60,80)
    s.Thickness = thick or 1
    s.Parent = parent
    return s
end

local function MakeFrame(p)
    local f = Instance.new("Frame")
    f.BorderSizePixel = 0
    for k, v in pairs(p) do pcall(function() f[k] = v end) end
    return f
end

local function MakeLabel(p)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.BorderSizePixel = 0
    l.Font = Enum.Font.Gotham
    for k, v in pairs(p) do pcall(function() l[k] = v end) end
    return l
end

