                end))
                local hD=false
                AddConn(hueHolder.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        hD=true
                        h=math.clamp((i.Position.X-hueHolder.AbsolutePosition.X)/
                            math.max(hueHolder.AbsoluteSize.X,1),0,1); UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputChanged:Connect(function(i)
                    if hD and i.UserInputType==Enum.UserInputType.MouseMovement then
                        h=math.clamp((i.Position.X-hueHolder.AbsolutePosition.X)/
                            math.max(hueHolder.AbsoluteSize.X,1),0,1); UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then hD=false end
                end))
                local aD=false
                AddConn(aHolder.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        aD=true
                        alpha=math.clamp((i.Position.X-aHolder.AbsolutePosition.X)/
                            math.max(aHolder.AbsoluteSize.X,1),0,1); UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputChanged:Connect(function(i)
                    if aD and i.UserInputType==Enum.UserInputType.MouseMovement then
                        alpha=math.clamp((i.Position.X-aHolder.AbsolutePosition.X)/
                            math.max(aHolder.AbsoluteSize.X,1),0,1); UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then aD=false end
                end))
                hexBox.FocusLost:Connect(function()
                    local hex=hexBox.Text:gsub("#",""):gsub("[^%x]","")
                    if #hex==6 then
                        local nc=Color3.new(
                            tonumber(hex:sub(1,2),16)/255,
                            tonumber(hex:sub(3,4),16)/255,
                            tonumber(hex:sub(5,6),16)/255)
                        h,s,v=Color3.toHSV(nc); UpdateVisuals()
                    end
                end)
                prev.MouseButton1Click:Connect(function()
                    open2=not open2; panel.Visible=open2
                    if open2 then row.AutomaticSize=Enum.AutomaticSize.Y; UpdateVisuals()
                    else row.AutomaticSize=Enum.AutomaticSize.None; row.Size=UDim2.new(1,0,0,36) end
                end)
                function Cp:Set(c,a)
                    clr=c; h,s,v=Color3.toHSV(c)
                    if a~=nil then alpha=math.clamp(a,0,1) end
                    prev.BackgroundColor3=c
                    if flag then NexusLib.Flags[flag]=c end; UpdateVisuals()
                end
                function Cp:Get() return clr end
                function Cp:GetAlpha() return alpha end
                function Cp:SetCallback(f) cb=f end
                UpdateVisuals(); AE(row); return Cp
            end

            -- ── CREDIT ──────────────────────────────────────
            function Sec:AddCredit(o)
                local row=MakeFrame({Size=UDim2.new(1,0,0,44),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,40),Position=UDim2.new(0,8,0,2),
                    ZIndex=14,Parent=row})
                R(bg,"BackgroundColor3","ElementBg"); MakeCorner(bg,6)
                local nl=MakeLabel({Size=UDim2.new(1,-12,0,20),Position=UDim2.new(0,10,0,4),
                    Text=o.Name or "Author",Font=Enum.Font.GothamBold,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                R(nl,"TextColor3","TextPrimary")
                local dl=MakeLabel({Size=UDim2.new(1,-12,0,14),Position=UDim2.new(0,10,0,23),
                    Text=o.Description or "",TextSize=11,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                R(dl,"TextColor3","TextDim"); AE(row)
            end

            function Sec:AddAccordion(o)
                return NexusLib._makeAccordion(elems, theme, o.Name or "Group", 0, function() end)
            end
            
            return Sec
        end

        -- Tab:AddAccordion
        function Tab:AddAccordion(o)
            return NexusLib._makeAccordion(page, theme, o.Name or "Group", 0, function() end)
        end

        return Tab
    end

    return Win
end

return NexusLib
