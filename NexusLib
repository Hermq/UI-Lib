-- ── Library Methods ───────────────────────────────────────
function NexusLib:Destroy()
    if self._gui and self._gui.Parent then self._gui:Destroy() end
    for _, c in pairs(self.Connections) do
        if typeof(c)=="RBXScriptConnection" then pcall(function() c:Disconnect() end) end
    end
    self.Connections={}; self.Flags={}; self.Options={}; self._listening=false
    if getgenv then getgenv()._NexusLibInstance=nil end
end

function NexusLib:SetTheme(t)
    self._theme = type(t)=="string" and (self.Themes[t] or self.Themes.Dark) or t
end
NexusLib:SetTheme("Dark")

-- ── Notify ────────────────────────────────────────────────
function NexusLib:Notify(opts)
    local th=self._theme
    local title=opts.Title or "Notice"; local text=opts.Text or ""
    local duration=opts.Duration or 4; local nType=opts.Type or "Info"
    local aclr=th.Accent
    if nType=="Success" then aclr=th.Success
    elseif nType=="Danger"  then aclr=th.Danger
    elseif nType=="Warning" then aclr=th.Warning end

    local offset=0
    for _,ch in ipairs(gui:GetChildren()) do if ch.Name=="NexusNotif" then offset=offset+76 end end

    local notif=MakeFrame({Name="NexusNotif",Size=UDim2.new(0,280,0,66),
        Position=UDim2.new(1,10,1,-(76+offset)),
        BackgroundColor3=th.SecondaryBg,BackgroundTransparency=1,ZIndex=200,Parent=gui})
    MakeCorner(notif,8); MakeStroke(notif,th.Border)
    local stripe=MakeFrame({Size=UDim2.new(0,3,1,0),BackgroundColor3=aclr,ZIndex=201,Parent=notif})
    MakeCorner(stripe,3)
    MakeLabel({Size=UDim2.new(1,-20,0,20),Position=UDim2.new(0,12,0,8),Text=title,
        Font=Enum.Font.GothamBold,TextSize=13,TextColor3=th.TextPrimary,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=202,Parent=notif})
    MakeLabel({Size=UDim2.new(1,-20,0,30),Position=UDim2.new(0,12,0,28),Text=text,
        TextSize=12,TextColor3=th.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true,ZIndex=202,Parent=notif})
    local bar=MakeFrame({Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=aclr,ZIndex=202,Parent=notif})

    TweenSpring(notif,{Position=UDim2.new(1,-290,1,-(76+offset)),BackgroundTransparency=0},0.4)
    Tween(bar,{Size=UDim2.new(0,0,0,2)},duration,Enum.EasingStyle.Linear)
    task.delay(duration,function()
        TweenSine(notif,{Position=UDim2.new(1,10,1,-(76+offset)),BackgroundTransparency=1},0.3)
        task.delay(0.35,function() notif:Destroy(); if opts.Callback then opts.Callback() end end)
    end)
end

-- ── Prompt ────────────────────────────────────────────────
function NexusLib:Prompt(opts)
    local th=self._theme
    local title=opts.Title or "Prompt"; local text=opts.Text or ""
    local buttons=opts.Buttons or {OK=function()end}

    local overlay=MakeFrame({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),
        BackgroundTransparency=1,ZIndex=500,Parent=gui})
    TweenSine(overlay,{BackgroundTransparency=0.5},0.2)

    local W,H=360,176
    local modal=MakeFrame({Size=UDim2.new(0,W*0.9,0,H*0.9),
        Position=UDim2.new(0.5,-W*0.9/2,0.5,-H*0.9/2),
        BackgroundColor3=th.SecondaryBg,BackgroundTransparency=1,ZIndex=501,Parent=gui})
    MakeCorner(modal,10); MakeStroke(modal,th.Border)
    MakeLabel({Size=UDim2.new(1,-20,0,24),Position=UDim2.new(0,14,0,10),Text=title,
        Font=Enum.Font.GothamBold,TextSize=15,TextColor3=th.TextPrimary,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=502,Parent=modal})
    MakeLabel({Size=UDim2.new(1,-20,0,80),Position=UDim2.new(0,14,0,38),Text=text,
        TextSize=13,TextColor3=th.TextSecondary,TextWrapped=true,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=502,Parent=modal})

    TweenSpring(modal,{
        Size=UDim2.new(0,W,0,H),
        Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        BackgroundTransparency=0
    },0.35)

    local btnCount=0; for _ in pairs(buttons) do btnCount=btnCount+1 end
    local btnW=math.min(110,(W-28)/btnCount-8); local bx=14; local by=H-48

    local function close()
        TweenSine(overlay,{BackgroundTransparency=1},0.2)
        TweenSine(modal,{Size=UDim2.new(0,W*0.9,0,H*0.9),BackgroundTransparency=1},0.2)
        task.delay(0.25,function() overlay:Destroy(); modal:Destroy() end)
    end

    for lbl,cb in pairs(buttons) do
        local b=Instance.new("TextButton")
        b.Size=UDim2.new(0,btnW,0,32); b.Position=UDim2.new(0,bx,0,by)
        b.BackgroundColor3=th.ElementBg; b.Text=lbl; b.Font=Enum.Font.GothamBold
        b.TextSize=12; b.TextColor3=th.TextPrimary; b.BorderSizePixel=0
        b.ZIndex=503; b.AutoButtonColor=false; b.Parent=modal
        MakeCorner(b,6)
        AddHoverScale(b); AddPressScale(b); AddGlow(b,th)
        b.MouseEnter:Connect(function() Tween(b,{BackgroundColor3=th.Accent},0.1) end)
        b.MouseLeave:Connect(function() Tween(b,{BackgroundColor3=th.ElementBg},0.1) end)
        b.MouseButton1Click:Connect(function() close(); if cb then cb() end end)
        bx=bx+btnW+8
    end
    return modal
end

