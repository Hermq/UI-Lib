        kbtn.Text=cur and cur.Name or "None"; kbtn.Font=Enum.Font.GothamBold
        kbtn.TextSize=11; kbtn.BorderSizePixel=0; kbtn.ZIndex=21+selfDepth
        kbtn.AutoButtonColor=false
        kbtn.BackgroundColor3=theme.TertiaryBg; kbtn.TextColor3=theme.TextSecondary
        kbtn.Parent=bg; MakeCorner(kbtn,5); AddHoverScale(kbtn); AddPressScale(kbtn)
        kbtn.MouseButton1Click:Connect(function()
            listening=true; NexusLib._listening=true
            kbtn.Text="..."; kbtn.TextColor3=theme.Accent
        end)
        AddConn(UserInputService.InputBegan:Connect(function(inp,gp)
            if listening then
                if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
                listening=false; NexusLib._listening=false
                if inp.KeyCode==Enum.KeyCode.Escape then
                    cur=nil; if flag then NexusLib.Flags[flag]=nil end
                    kbtn.Text="None"; kbtn.TextColor3=theme.TextSecondary
                elseif BLOCK[inp.KeyCode] then
                    kbtn.Text=cur and cur.Name or "None"; kbtn.TextColor3=theme.TextSecondary
                else
                    cur=inp.KeyCode; if flag then NexusLib.Flags[flag]=cur end
                    kbtn.Text=cur.Name; kbtn.TextColor3=theme.Accent
                    task.delay(0.4,function() kbtn.TextColor3=theme.TextSecondary end)
                end
            else
                if NexusLib._listening then return end
                if not gp and inp.UserInputType==Enum.UserInputType.Keyboard
                    and cur and inp.KeyCode==cur then cb() end
            end
        end))
        local KB={}
        function KB:Set(k) cur=k; if flag then NexusLib.Flags[flag]=k end
            kbtn.Text=k and k.Name or "None" end
        function KB:Get() return cur end
        function KB:SetCallback(f) cb=f end
        if flag then NexusLib.Options[flag]=KB end
        
        if hasDesc then
            local arrow, dLbl = AddDescriptionUI(bg, desc, theme)
            local expanded = false
            arrow.MouseButton1Click:Connect(function()
                expanded = not expanded
                if expanded then
                    row.Size = UDim2.new(1, 0, 0, 62)
