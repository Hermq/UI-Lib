                -- SV field (square gradient)
                local svHolder=MakeFrame({Size=UDim2.new(1,0,0,120),BackgroundColor3=Color3.fromHSV(h,1,1),ZIndex=15,LayoutOrder=1,Parent=panel})
                MakeCorner(svHolder,4)
                -- white gradient left→right (inverted for saturation)
                local whiteGrad=Instance.new("UIGradient"); whiteGrad.Color=ColorSequence.new(Color3.new(1,1,1),Color3.new(1,1,1)); whiteGrad.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)}); whiteGrad.Rotation=0; whiteGrad.Parent=svHolder
                -- black gradient top→bottom
                local svDark=MakeFrame({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),ZIndex=16,Parent=svHolder})
                MakeCorner(svDark,4)
                local blackGrad=Instance.new("UIGradient"); blackGrad.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)}); blackGrad.Rotation=90; blackGrad.Parent=svDark
                -- cursor
                local svCursor=MakeFrame({Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(0.5,0.5),BackgroundColor3=Color3.new(1,1,1),ZIndex=18,Parent=svHolder})
                MakeCorner(svCursor,5)
                MakeStroke(svCursor,Color3.new(0,0,0),2)

                -- Hue bar
                local hueHolder=MakeFrame({Size=UDim2.new(1,0,0,16),BackgroundColor3=Color3.new(1,1,1),ZIndex=15,LayoutOrder=2,Parent=panel})
                MakeCorner(hueHolder,4)
                local hueGrad=Instance.new("UIGradient")
                hueGrad.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,1,1)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17,1,1)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33,1,1)),
                    ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5,1,1)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67,1,1)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83,1,1)),
                    ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,1,1)),
                })
                hueGrad.Parent=hueHolder
                local hueCursor=MakeFrame({Size=UDim2.new(0,4,1,0),AnchorPoint=Vector2.new(0.5,0),BackgroundColor3=Color3.new(1,1,1),ZIndex=17,Parent=hueHolder})
                MakeCorner(hueCursor,2)
                MakeStroke(hueCursor,Color3.new(0,0,0),1)

                -- Hex input
                local hexRow=MakeFrame({Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,ZIndex=15,LayoutOrder=3,Parent=panel})
                local hexLL=Instance.new("UIListLayout"); hexLL.FillDirection=Enum.FillDirection.Horizontal; hexLL.SortOrder=Enum.SortOrder.LayoutOrder; hexLL.Padding=UDim.new(0,6); hexLL.Parent=hexRow
                local hexPre=MakeLabel({Size=UDim2.new(0,14,1,0),Text="#",TextSize=12,TextColor3=theme.TextDim,ZIndex=16,Parent=hexRow})
                local hexBox=Instance.new("TextBox")
                hexBox.Size=UDim2.new(0.6,0,1,0); hexBox.BackgroundColor3=theme.ElementBg; hexBox.BorderSizePixel=0
                hexBox.Font=Enum.Font.Code; hexBox.TextSize=12; hexBox.TextColor3=theme.TextPrimary
                hexBox.Text=""; hexBox.ZIndex=16; hexBox.Parent=hexRow
                MakeCorner(hexBox,4)

                local Cp={}
                local open2=false

                local function UpdateVisuals()
                    svHolder.BackgroundColor3=Color3.fromHSV(h,1,1)
                    local px=math.clamp(s,0,1); local py=1-math.clamp(v,0,1)
                    svCursor.Position=UDim2.new(px,-5,py,-5)
                    hueCursor.Position=UDim2.new(h,-2,0,0)
                    clr=Color3.fromHSV(h,s,v); prev.BackgroundColor3=clr
                    hexBox.Text=clr:ToHex()
                    if flag then NexusLib.Flags[flag]=clr end
                    cb(clr)
                end

                -- SV dragging
                local svDragging=false
                AddConn(svHolder.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        svDragging=true
                        local ap=svHolder.AbsolutePosition; local as=svHolder.AbsoluteSize
                        s=math.clamp((i.Position.X-ap.X)/as.X,0,1)
                        v=1-math.clamp((i.Position.Y-ap.Y)/as.Y,0,1)
                        UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputChanged:Connect(function(i)
                    if svDragging and i.UserInputType==Enum.UserInputType.MouseMovement then
                        local ap=svHolder.AbsolutePosition; local as=svHolder.AbsoluteSize
                        s=math.clamp((i.Position.X-ap.X)/as.X,0,1)
                        v=1-math.clamp((i.Position.Y-ap.Y)/as.Y,0,1)
                        UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then svDragging=false end
                end))

                -- Hue dragging
                local hueDragging=false
                AddConn(hueHolder.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        hueDragging=true
                        h=math.clamp((i.Position.X-hueHolder.AbsolutePosition.X)/math.max(hueHolder.AbsoluteSize.X,1),0,1)
                        UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputChanged:Connect(function(i)
                    if hueDragging and i.UserInputType==Enum.UserInputType.MouseMovement then
                        h=math.clamp((i.Position.X-hueHolder.AbsolutePosition.X)/math.max(hueHolder.AbsoluteSize.X,1),0,1)
                        UpdateVisuals()
                    end
                end))
                AddConn(UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDragging=false end
                end))

                -- Hex input
                hexBox.FocusLost:Connect(function()
                    local hex=hexBox.Text:gsub("#",""):gsub("[^%x]","")
                    if #hex==6 then
                        local r=tonumber(hex:sub(1,2),16)/255
                        local g2=tonumber(hex:sub(3,4),16)/255
                        local b2=tonumber(hex:sub(5,6),16)/255
                        local nc=Color3.new(r,g2,b2)
                        h,s,v=Color3.toHSV(nc)
                        UpdateVisuals()
                    end
                end)

                -- Toggle open
                prev.MouseButton1Click:Connect(function()
                    open2=not open2
                    panel.Visible=open2
                    row.Size=UDim2.new(1,0,0,open2 and 0 or 36)
                    row.AutomaticSize=open2 and Enum.AutomaticSize.Y or Enum.AutomaticSize.None
                    if open2 then
                        row.Size=UDim2.new(1,0,0,0)
                        row.AutomaticSize=Enum.AutomaticSize.Y
                        UpdateVisuals()
                    else
                        row.AutomaticSize=Enum.AutomaticSize.None
                        row.Size=UDim2.new(1,0,0,36)
                    end
                end)

                function Cp:Set(c)
                    clr=c; h,s,v=Color3.toHSV(c)
                    prev.BackgroundColor3=c
                    if flag then NexusLib.Flags[flag]=c end
                    UpdateVisuals()
                end
                function Cp:Get() return clr end
                function Cp:SetCallback(f) cb=f end

                UpdateVisuals()
                AE(row); return Cp
            end

            -- CREDIT ──────────────────────────────────────
            function Sec:AddCredit(o)
                local row=MakeFrame({Size=UDim2.new(1,0,0,44),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,40),Position=UDim2.new(0,8,0,2),BackgroundColor3=theme.ElementBg,ZIndex=14,Parent=row})
                MakeCorner(bg,6)
                MakeLabel({Size=UDim2.new(1,-12,0,20),Position=UDim2.new(0,10,0,4),Text=o.Name or "Author",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=theme.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                MakeLabel({Size=UDim2.new(1,-12,0,14),Position=UDim2.new(0,10,0,23),Text=o.Description or "",TextSize=11,TextColor3=theme.TextDim,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                AE(row)
            end

            return Sec
        end

        return Tab
    end

    return Win
end

return NexusLib
