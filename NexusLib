        SV(val,false)
        local sliding=false
        local function doSlide(x)
            local p=math.clamp((x-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1)
            SV(smin+(smax-smin)*p,true)
        end
        AddConn(track.InputBegan:Connect(function(i)
