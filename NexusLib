            -- SLIDER ─────────────────────────────────────
            -- FreeInput=true lets the typed value go beyond Min/Max
            function Sec:AddSlider(o)
                local n=o.Name or "Slider"; local smin=o.Min or 0; local smax=o.Max or 100
                local def=o.Default or smin; local sfx=o.Suffix or ""; local prec=o.Precision or 0
                local flag=o.Flag; local cb=o.Callback or function()end; local free=o.FreeInput or false
                local val=math.clamp(def,smin,smax)
                if flag then NexusLib.Flags[flag]=val end

                local row=MakeFrame({Size=UDim2.new(1,0,0,58),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,54),Position=UDim2.new(0,8,0,2),BackgroundColor3=theme.ElementBg,ZIndex=14,Parent=row})
                MakeCorner(bg,6)
                MakeLabel({Size=UDim2.new(0.6,0,0,20),Position=UDim2.new(0,10,0,6),Text=n,Font=Enum.Font.Gotham,TextSize=13,TextColor3=theme.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})

                local vbox=Instance.new("TextBox")
                vbox.Size=UDim2.new(0,72,0,22); vbox.Position=UDim2.new(1,-80,0,5)
                vbox.BackgroundColor3=theme.TertiaryBg; vbox.BorderSizePixel=0
                vbox.Font=Enum.Font.GothamBold; vbox.TextSize=12; vbox.TextColor3=theme.Accent
                vbox.TextXAlignment=Enum.TextXAlignment.Center; vbox.ClearTextOnFocus=true
                vbox.ZIndex=15; vbox.Parent=bg
                MakeCorner(vbox,4)

                local track=MakeFrame({Size=UDim2.new(1,-20,0,6),Position=UDim2.new(0,10,0,36),BackgroundColor3=theme.TertiaryBg,ZIndex=15,Parent=bg})
                MakeCorner(track,3)
                local fill=MakeFrame({Size=UDim2.new(0,0,1,0),BackgroundColor3=theme.Accent,ZIndex=16,Parent=track})
                MakeCorner(fill,3)
                local thumb=MakeFrame({Size=UDim2.new(0,12,0,12),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=17,Parent=track})
                MakeCorner(thumb,6)

                local Sli={}
                local function Fmt(v)
                    if prec==0 then return tostring(math.floor(v+0.5))..sfx
                    else return string.format("%."..prec.."f",v)..sfx end
                end
                local function SV(v,fire,skipClamp)
                    if not skipClamp then v=math.clamp(v,smin,smax) end
                    if prec==0 then v=math.floor(v+0.5) end
                    val=v; if flag then NexusLib.Flags[flag]=v end
                    local p=(smax-smin>0) and math.clamp((v-smin)/(smax-smin),0,1) or 0
                    fill.Size=UDim2.new(p,0,1,0); thumb.Position=UDim2.new(p,-6,0.5,-6)
                    vbox.Text=Fmt(v); if fire then cb(v) end
                end
                SV(val,false)

                local sliding=false
                local function DoSlide(x) SV(smin+(smax-smin)*math.clamp((x-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1),true) end
                AddConn(track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; DoSlide(i.Position.X) end end))
                AddConn(thumb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true end end))
                AddConn(UserInputService.InputChanged:Connect(function(i) if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then DoSlide(i.Position.X) end end))
                AddConn(UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end))
                vbox.FocusLost:Connect(function()
                    local num=tonumber(vbox.Text:gsub("[^%d%.%-]",""))
                    if num then SV(num,true,free) else vbox.Text=Fmt(val) end
                end)

                function Sli:Set(v,skipClamp) SV(v,false,skipClamp) end
                function Sli:Get() return val end
                function Sli:SetCallback(f) cb=f end
                AE(row); return Sli
            end

