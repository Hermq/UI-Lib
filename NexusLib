            -- ── TOGGLE ──────────────────────────────────────
            function Sec:AddToggle(o)
                local n=o.Name or "Toggle"; local d=o.Description; local st=o.Default or false
                local flag=o.Flag; local cb=o.Callback or function()end; local rh=d and 54 or 36
                if flag then NexusLib.Flags[flag]=st end
                local row=MakeFrame({Size=UDim2.new(1,0,0,rh),BackgroundTransparency=1,ZIndex=14})
                local bg=Instance.new("TextButton")
                bg.Size=UDim2.new(1,-16,0,rh-4); bg.Position=UDim2.new(0,8,0,2)
                bg.Text=""; bg.BorderSizePixel=0; bg.ZIndex=14; bg.AutoButtonColor=false; bg.Parent=row
                R(bg,"BackgroundColor3","ElementBg"); MakeCorner(bg,6)
                AddHoverScale(bg); AddPressScale(bg); AddGlow(bg,theme)
                local nl=MakeLabel({Size=UDim2.new(1,-60,0,20),Position=UDim2.new(0,10,0,d and 7 or 9),
                    Text=n,Font=Enum.Font.Gotham,TextSize=13,TextXAlignment=Enum.TextXAlignment.Left,
                    ZIndex=15,Parent=bg})
                R(nl,"TextColor3","TextPrimary")
                if d then
                    local dl=MakeLabel({Size=UDim2.new(1,-60,0,16),Position=UDim2.new(0,10,0,27),
                        Text=d,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                    R(dl,"TextColor3","TextDim")
                end
                local pill=MakeFrame({Size=UDim2.new(0,36,0,20),Position=UDim2.new(1,-46,0.5,-10),
                    ZIndex=15,Parent=bg})
                R(pill,"BackgroundColor3",st and "ToggleOn" or "ToggleOff"); MakeCorner(pill,10)
                local dot=MakeFrame({Size=UDim2.new(0,14,0,14),
                    Position=st and UDim2.new(0,19,0.5,-7) or UDim2.new(0,3,0.5,-7),
                    BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=16,Parent=pill})
                MakeCorner(dot,7)
                local Tog={}
                local function SetSt(s,fire)
                    st=s; if flag then NexusLib.Flags[flag]=s end
                    Tween(pill,{BackgroundColor3=s and theme.ToggleOn or theme.ToggleOff},0.2)
                    Tween(dot,{Size=UDim2.new(0,10,0,14)},0.07)
                    task.delay(0.07,function()
                        Tween(dot,{Position=s and UDim2.new(0,19,0.5,-7) or UDim2.new(0,3,0.5,-7)},
                            0.18,Enum.EasingStyle.Quart)
                        TweenSpring(dot,{Size=UDim2.new(0,14,0,14)},0.25)
                    end)
                    if fire then cb(s) end
                end
                bg.MouseEnter:Connect(function() Tween(bg,{BackgroundColor3=theme.ElementHover},0.1) end)
                bg.MouseLeave:Connect(function() Tween(bg,{BackgroundColor3=theme.ElementBg},0.1) end)
                bg.MouseButton1Click:Connect(function() SetSt(not st,true) end)
                function Tog:Set(s,fire) SetSt(s, fire==true) end
                function Tog:Get() return st end
                function Tog:SetCallback(f) cb=f end
                if flag then NexusLib.Options[flag]=Tog end
                AE(row); return Tog
            end

            -- ── SLIDER (with Polarity support) ───────────────
            function Sec:AddSlider(o)
                local n=o.Name or "Slider"; local prec=o.Precision or 0
                local sfx=o.Suffix or ""; local flag=o.Flag
                local cb=o.Callback or function()end; local free=o.FreeInput or false
                local polarity=o.Polarity or false
                local smin = polarity and 0 or (o.Min or 0)
                local smax = o.Max or 100
                local def  = o.Default or smin
                local sign = (def < 0) and -1 or 1
                local mag  = math.abs(def)
                if not polarity then mag = math.clamp(def, smin, smax); sign = 1 end
                local val = polarity and (mag * sign) or mag
                if flag then NexusLib.Flags[flag]=val end
                local bgH  = polarity and 82 or 54
                local rowH = polarity and 86 or 58
                local row=MakeFrame({Size=UDim2.new(1,0,0,rowH),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,bgH),Position=UDim2.new(0,8,0,2),
                    ZIndex=14,Parent=row})
                R(bg,"BackgroundColor3","ElementBg"); MakeCorner(bg,6)
                AddHoverScale(bg); AddGlow(bg,theme)
                local nl=MakeLabel({Size=UDim2.new(0.6,0,0,20),Position=UDim2.new(0,10,0,6),
                    Text=n,Font=Enum.Font.Gotham,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                R(nl,"TextColor3","TextPrimary")
                local vbox=Instance.new("TextBox")
                vbox.Size=UDim2.new(0,72,0,22); vbox.Position=UDim2.new(1,-80,0,5)
                vbox.BorderSizePixel=0; vbox.Font=Enum.Font.GothamBold; vbox.TextSize=12
                vbox.TextXAlignment=Enum.TextXAlignment.Center; vbox.ClearTextOnFocus=true
                vbox.ZIndex=15; vbox.Parent=bg
                R(vbox,"BackgroundColor3","TertiaryBg"); R(vbox,"TextColor3","Accent"); MakeCorner(vbox,4)
                local track=MakeFrame({Size=UDim2.new(1,-20,0,6),Position=UDim2.new(0,10,0,36),
                    ZIndex=15,Parent=bg})
                R(track,"BackgroundColor3","TertiaryBg"); MakeCorner(track,3)
                local fill=MakeFrame({Size=UDim2.new(0,0,1,0),ZIndex=16,Parent=track})
                R(fill,"BackgroundColor3","Accent"); MakeCorner(fill,3)
                local thumb=MakeFrame({Size=UDim2.new(0,12,0,12),
                    BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=17,Parent=track})
                MakeCorner(thumb,6)
                local polarityBtn = nil
                if polarity then
                    polarityBtn = Instance.new("TextButton")
                    polarityBtn.Size=UDim2.new(1,-20,0,22); polarityBtn.Position=UDim2.new(0,10,0,50)
                    polarityBtn.Font=Enum.Font.GothamBold; polarityBtn.TextSize=11
                    polarityBtn.BorderSizePixel=0; polarityBtn.ZIndex=15
                    polarityBtn.AutoButtonColor=false; polarityBtn.Parent=bg
                    MakeCorner(polarityBtn,5); AddHoverScale(polarityBtn); AddPressScale(polarityBtn)
                end
                local Sli={}
                local function Fmt(v)
                    if prec==0 then
                        local a=math.floor(math.abs(v)+0.5)
                        return tostring(v<0 and -a or a)..sfx
                    end
                    return string.format("%."..prec.."f",v)..sfx
                end
                local function UpdatePill()
                    if not polarityBtn then return end
                    local isPos=(sign>=0)
                    local col=isPos and theme.Success or theme.Danger
                    Tween(polarityBtn,{BackgroundColor3=col},0.15)
                    polarityBtn.TextColor3=Color3.fromRGB(255,255,255)
                    polarityBtn.Text=isPos and "＋  POSITIVE" or "－  NEGATIVE"
                end
                local function SV(v,fire,skipClamp)
                    if polarity then
                        if v~=0 then sign=(v<0) and -1 or 1 end
                        local m=math.abs(v)
                        if not skipClamp then m=math.clamp(m,0,smax) end
                        if prec==0 then m=math.floor(m+0.5) end
                        mag=m; val=mag*sign
                    else
                        if not skipClamp then v=math.clamp(v,smin,smax) end
                        if prec==0 then v=math.floor(v+0.5) end
                        val=v; mag=v
                    end
                    if flag then NexusLib.Flags[flag]=val end
                    local p=(smax>0) and math.clamp(mag/smax,0,1) or 0
                    fill.Size=UDim2.new(p,0,1,0)
                    thumb.Position=UDim2.new(p,-6,0.5,-6)
                    vbox.Text=Fmt(val); UpdatePill()
                    if fire then cb(val) end
                end
                SV(def,false)
                if polarityBtn then
                    polarityBtn.MouseButton1Click:Connect(function()
                        sign=-sign; val=mag*sign
                        if flag then NexusLib.Flags[flag]=val end
                        vbox.Text=Fmt(val); UpdatePill(); cb(val)
                    end)
                end
                local sliding=false
                local function DoSlide(x)
                    local m=smax*math.clamp(
                        (x-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1)
                    SV(polarity and (m*sign) or (smin+(smax-smin)*math.clamp(
                        (x-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1)),true)
                end
                AddConn(track.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        sliding=true; DoSlide(i.Position.X)
                        TweenSpring(thumb,{Size=UDim2.new(0,16,0,16)},0.2)
                    end
                end))
                AddConn(thumb.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then
                        sliding=true; TweenSpring(thumb,{Size=UDim2.new(0,16,0,16)},0.2)
                    end
                end))
                AddConn(UserInputService.InputChanged:Connect(function(i)
                    if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then DoSlide(i.Position.X) end
                end))
                AddConn(UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 and sliding then
                        sliding=false; TweenSine(thumb,{Size=UDim2.new(0,12,0,12)},0.15)
                    end
                end))
                vbox.FocusLost:Connect(function()
                    local raw=vbox.Text:gsub(",",".")
                    local num=tonumber(raw:match("[%-+]?%d*%.?%d+") or "")
                    if num then SV(num,true,free) else vbox.Text=Fmt(val) end
                end)
                function Sli:Set(v,skipClamp) SV(v,false,skipClamp) end
                function Sli:Get() return val end
                function Sli:SetCallback(f) cb=f end
                if flag then NexusLib.Options[flag]=Sli end
                AE(row); return Sli
            end

            -- ── KEYBIND ─────────────────────────────────────
            function Sec:AddKeybind(o)
                local n=o.Name or "Keybind"; local def=o.Default; local flag=o.Flag
                local cb=o.Callback or function()end
                local cur=def; local listening=false
                if flag then NexusLib.Flags[flag]=cur end
                local BLOCK={
                    [Enum.KeyCode.Unknown]=true,[Enum.KeyCode.W]=true,
                    [Enum.KeyCode.A]=true,[Enum.KeyCode.S]=true,[Enum.KeyCode.D]=true,
                    [Enum.KeyCode.Space]=true,[Enum.KeyCode.Return]=true,
                    [Enum.KeyCode.LeftShift]=true,[Enum.KeyCode.LeftControl]=true,
                    [Enum.KeyCode.LeftAlt]=true,[Enum.KeyCode.RightAlt]=true,
                }
                local row=MakeFrame({Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ZIndex=14})
                local bg=MakeFrame({Size=UDim2.new(1,-16,0,32),Position=UDim2.new(0,8,0,2),
                    ZIndex=14,Parent=row})
                R(bg,"BackgroundColor3","ElementBg"); MakeCorner(bg,6); AddGlow(bg,theme)
                local nl=MakeLabel({Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,10,0,0),
                    Text=n,Font=Enum.Font.Gotham,TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                R(nl,"TextColor3","TextPrimary")
                local kbtn=Instance.new("TextButton")
                kbtn.Size=UDim2.new(0,94,0,22); kbtn.Position=UDim2.new(1,-102,0.5,-11)
                kbtn.Text=cur and cur.Name or "None"; kbtn.Font=Enum.Font.GothamBold
                kbtn.TextSize=12; kbtn.BorderSizePixel=0; kbtn.ZIndex=15
                kbtn.AutoButtonColor=false; kbtn.Parent=bg
                R(kbtn,"BackgroundColor3","TertiaryBg"); R(kbtn,"TextColor3","TextSecondary")
                MakeCorner(kbtn,5); AddHoverScale(kbtn); AddPressScale(kbtn)
                kbtn.MouseButton1Click:Connect(function()
                    listening=true; NexusLib._listening=true
                    kbtn.Text="..."; kbtn.TextColor3=theme.Accent
                    kbtn.BackgroundTransparency=0
                    local function doPulse()
                        if not listening then kbtn.BackgroundTransparency=0; return end
                        Tween(kbtn,{BackgroundTransparency=0.45},0.35)
                        task.delay(0.36,function()
                            if not listening then kbtn.BackgroundTransparency=0; return end
                            Tween(kbtn,{BackgroundTransparency=0},0.35)
                            task.delay(0.36,doPulse)
                        end)
                    end
                    doPulse()
                end)
                AddConn(UserInputService.InputBegan:Connect(function(inp,gp)
                    if listening then
                        if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
                        listening=false; NexusLib._listening=false
                        kbtn.BackgroundTransparency=0
                        if inp.KeyCode==Enum.KeyCode.Escape then
                            cur=nil; if flag then NexusLib.Flags[flag]=nil end
                            kbtn.Text="None"; kbtn.TextColor3=theme.TextSecondary
                        elseif BLOCK[inp.KeyCode] then
                            kbtn.Text=cur and cur.Name or "None"; kbtn.TextColor3=theme.TextSecondary
                        else
                            cur=inp.KeyCode; if flag then NexusLib.Flags[flag]=cur end
                            kbtn.TextColor3=theme.Accent; kbtn.Text=cur.Name
                            task.delay(0.4,function() kbtn.TextColor3=theme.TextSecondary end)
                        end
                    else
                        if NexusLib._listening then return end
