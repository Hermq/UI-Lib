-- ── Tween helpers ─────────────────────────────────────────
local function Tween(obj, props, t, style, dir)
    local ok, tw = pcall(function()
        return TweenService:Create(obj,
            TweenInfo.new(t or 0.15,
                style or Enum.EasingStyle.Quint,
                dir   or Enum.EasingDirection.Out),
            props)
    end)
    if ok and tw then tw:Play(); return tw end
end

local function TweenSpring(obj, props, t)
    return Tween(obj, props, t or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
end

local function TweenSine(obj, props, t)
    return Tween(obj, props, t or 0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
end

-- ── Micro-animation helpers ────────────────────────────────
local function AddHoverScale(obj)
    local us = Instance.new("UIScale"); us.Scale = 1; us.Parent = obj
    obj.MouseEnter:Connect(function() Tween(us, {Scale=1.025}, 0.12) end)
    obj.MouseLeave:Connect(function() Tween(us, {Scale=1},     0.12) end)
end

local function AddPressScale(obj)
    local us = obj:FindFirstChildOfClass("UIScale")
    if not us then us = Instance.new("UIScale"); us.Scale = 1; us.Parent = obj end
    obj.MouseButton1Down:Connect(function() Tween(us, {Scale=0.95}, 0.07) end)
    obj.MouseButton1Up:Connect(function()   TweenSpring(us, {Scale=1}, 0.2) end)
    obj.MouseLeave:Connect(function()       TweenSpring(us, {Scale=1}, 0.2) end)
end

local function AddGlow(obj, theme)
    local glow = Instance.new("UIStroke")
    glow.Thickness    = 0
    glow.Transparency = 1
    glow.Color        = theme.Accent
    glow.Parent       = obj
    obj.MouseEnter:Connect(function()
        Tween(glow, {Transparency=0.35, Thickness=1.5}, 0.15)
        Tween(glow, {Color=theme.AccentHover}, 0.15)
    end)
    obj.MouseLeave:Connect(function()
        Tween(glow, {Transparency=1, Thickness=0}, 0.15)
        Tween(glow, {Color=theme.Accent}, 0.15)
    end)
    return glow
end

local function AddConn(c) table.insert(NexusLib.Connections, c); return c end

local function MakeCorner(p, r)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, r or 8); c.Parent = p; return c
end

local function MakeStroke(p, col, thick)
    local s = Instance.new("UIStroke"); s.Color = col or Color3.fromRGB(60,60,80)
    s.Thickness = thick or 1; s.Parent = p; return s
end

local function MakeFrame(props)
    local f = Instance.new("Frame"); f.BorderSizePixel = 0
    for k, v in pairs(props) do pcall(function() f[k] = v end) end
    return f
end

local function MakeLabel(props)
    local l = Instance.new("TextLabel"); l.BackgroundTransparency = 1
    l.BorderSizePixel = 0; l.Font = Enum.Font.Gotham
    for k, v in pairs(props) do pcall(function() l[k] = v end) end
    return l
end

