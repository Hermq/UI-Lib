            BackgroundColor3=theme.ElementBg,ZIndex=20+selfDepth,Parent=row})
        MakeCorner(bg,6); AddGlow(bg,theme)
        local nl=MakeLabel({Size=UDim2.new(0.54,0,1,0),Position=UDim2.new(0,10,0,0),
