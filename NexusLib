                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=15,Parent=bg})
                R(nl,"TextColor3","TextPrimary")

                -- Right combined widget: a TextBox for search / display, arrow button
                local RIGHT_W=0.55  -- fraction of bg width
                local RIGHT_OFF=0.43
                local widgetHolder=MakeFrame({Size=UDim2.new(RIGHT_W,0,0,24),
                    Position=UDim2.new(RIGHT_OFF,0,0.5,-12),
                    ZIndex=15,Parent=bg})
                R(widgetHolder,"BackgroundColor3","TertiaryBg"); MakeCorner(widgetHolder,5)
                local wStroke=MakeStroke(widgetHolder,theme.Border,1)

                -- TextBox doubles as search when open, and shows selected when closed
                local tbox=Instance.new("TextBox")
                tbox.Size=UDim2.new(1,-24,1,0); tbox.Position=UDim2.new(0,6,0,0)
                tbox.BackgroundTransparency=1; tbox.BorderSizePixel=0
                tbox.Font=Enum.Font.Gotham; tbox.TextSize=12
                tbox.TextXAlignment=Enum.TextXAlignment.Left
                tbox.ClearTextOnFocus=false; tbox.TextEditable=false
                tbox.ZIndex=16; tbox.Parent=widgetHolder
                tbox.Text=selected~=nil and tostring(selected) or "Select..."
                tbox.TextColor3=selected~=nil and theme.Accent or theme.TextSecondary
                tbox.PlaceholderText="Search..."; tbox.PlaceholderColor3=theme.TextDim

                -- Arrow indicator
                local arrow=MakeLabel({Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-22,0,0),
                    Text="◀",TextSize=10,Font=Enum.Font.GothamBold,ZIndex=16,Parent=widgetHolder})
                R(arrow,"TextColor3","TextDim")

                -- Invisible click catcher over the whole widget (so clicking anywhere opens it)
                local clickCatch=Instance.new("TextButton")
                clickCatch.Size=UDim2.new(1,0,1,0); clickCatch.BackgroundTransparency=1
                clickCatch.Text=""; clickCatch.BorderSizePixel=0; clickCatch.ZIndex=17
                clickCatch.AutoButtonColor=false; clickCatch.Parent=widgetHolder

                -- ── Floating list ──────────────────────────────
                local listOuter=MakeFrame({Size=UDim2.new(0,10,0,0),ZIndex=80,
                    Visible=false,ClipsDescendants=true,Parent=gui})
                MakeCorner(listOuter,6); MakeStroke(listOuter,theme.Border)
                R(listOuter,"BackgroundColor3","TertiaryBg")

                -- Scrolling items (no separate search bar — tbox IS the search)
                local listFrame=Instance.new("ScrollingFrame")
                listFrame.Size=UDim2.new(1,0,1,0)
                listFrame.ScrollBarThickness=3; listFrame.BorderSizePixel=0
                listFrame.ScrollingDirection=Enum.ScrollingDirection.Y
                listFrame.CanvasSize=UDim2.new(0,0,0,0)
                listFrame.AutomaticCanvasSize=Enum.AutomaticSize.Y
                listFrame.ClipsDescendants=true; listFrame.BackgroundTransparency=1
                listFrame.ZIndex=81; listFrame.Parent=listOuter
                R(listFrame,"ScrollBarImageColor3","ScrollBar")
                local listLL=Instance.new("UIListLayout"); listLL.SortOrder=Enum.SortOrder.LayoutOrder
                listLL.Parent=listFrame
                local listPd=Instance.new("UIPadding")
                listPd.PaddingTop=UDim.new(0,3); listPd.PaddingBottom=UDim.new(0,3)
                listPd.Parent=listFrame

                local Drop={}
                local function Populate(filter)
                    filter=filter or ""
                    for _,c in pairs(listFrame:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    local fLow=filter:lower()
                    local count=0
                    for _,item in ipairs(items) do
                        local itemStr=tostring(item)
                        if fLow=="" or itemStr:lower():find(fLow,1,true) then
                            count=count+1
                            local ib=Instance.new("TextButton")
                            ib.Size=UDim2.new(1,0,0,28); ib.BackgroundColor3=theme.TertiaryBg
                            ib.Text="  "..itemStr; ib.Font=Enum.Font.Gotham; ib.TextSize=13
                            ib.TextColor3=(item==selected) and theme.Accent or theme.TextSecondary
                            ib.TextXAlignment=Enum.TextXAlignment.Left; ib.BorderSizePixel=0
                            ib.ZIndex=82; ib.AutoButtonColor=false; ib.Parent=listFrame
                            ib.MouseEnter:Connect(function() Tween(ib,{BackgroundColor3=theme.ElementHover},0.08) end)
                            ib.MouseLeave:Connect(function() Tween(ib,{BackgroundColor3=theme.TertiaryBg},0.08) end)
                            ib.MouseButton1Click:Connect(function()
                                selected=item
                                tbox.Text=tostring(item); tbox.TextColor3=theme.Accent
                                tbox.TextEditable=false
                                if flag then NexusLib.Flags[flag]=item end
                                cb(item); Drop:Close()
                            end)
                        end
                    end
                    return count
                end

                -- tbox text changes = live search filter while open
                tbox:GetPropertyChangedSignal("Text"):Connect(function()
                    if open and tbox.TextEditable then
                        Populate(tbox.Text)
                        -- resize list to match filtered count
                        local cnt=0
                        for _,c in pairs(listFrame:GetChildren()) do
                            if c:IsA("TextButton") then cnt=cnt+1 end
                        end
                        local newH=math.min(cnt,6)*28+6
                        if newH<6 then newH=6 end
                        TweenSine(listOuter,{Size=UDim2.new(0,listOuter.AbsoluteSize.X,0,newH)},0.12)
                    end
                end)

                -- Debounce so rapid clicks can't double-fire open/close
                local _busy = false
                local function _withDebounce(fn)
                    if _busy then return end
                    _busy = true
                    fn()
                    task.delay(0.25, function() _busy = false end)
                end

                function Drop:Open()
                    open = true
                    tbox.TextEditable = true
                    tbox.Text = ""
                    tbox.TextColor3 = theme.TextPrimary
                    Populate("")
                    Tween(arrow, {Rotation=-90}, 0.18)
                    Tween(wStroke, {Color=theme.Accent, Thickness=1.5}, 0.15)
                    -- Read absolute position NOW (layout already resolved on screen)
                    -- Use bg position+size so the list is full element width
                    local ap = bg.AbsolutePosition
                    local as = bg.AbsoluteSize
                    local w  = as.X
                    local listH = math.min(#items, 6) * 28 + 6
                    if listH < 6 then listH = 6 end
                    -- Always open BELOW the element; clamp to screen bottom
                    local screenH = workspace.CurrentCamera
                        and workspace.CurrentCamera.ViewportSize.Y or 800
                    local posY = ap.Y + as.Y + 2
                    if posY + listH > screenH - 4 then
                        posY = ap.Y - listH - 2   -- flip above only if truly no room
                    end
                    listOuter.Size     = UDim2.new(0, w, 0, 0)
                    listOuter.Position = UDim2.new(0, ap.X, 0, posY)
                    listOuter.Visible  = true
                    TweenSine(listOuter, {Size=UDim2.new(0, w, 0, listH)}, 0.2)
                    task.delay(0.05, function()
                        if open then tbox:CaptureFocus() end
                    end)
                end

                function Drop:Close()
                    open = false
                    tbox.TextEditable = false
                    tbox.Text = selected ~= nil and tostring(selected) or "Select..."
                    tbox.TextColor3 = selected ~= nil and theme.Accent or theme.TextSecondary
                    pcall(function() tbox:ReleaseFocus() end)
                    Tween(arrow, {Rotation=0}, 0.15)
                    Tween(wStroke, {Color=theme.Border, Thickness=1}, 0.15)
                    local w = listOuter.AbsoluteSize.X
                    TweenSine(listOuter, {Size=UDim2.new(0, w, 0, 0)}, 0.15)
                    task.delay(0.16, function() listOuter.Visible = false end)
                end

                function Drop:Set(v)
                    selected = v
                    if not open then
                        tbox.Text = v ~= nil and tostring(v) or "Select..."
                        tbox.TextColor3 = v ~= nil and theme.Accent or theme.TextSecondary
                    end
                    if flag then NexusLib.Flags[flag] = v end
                end
                function Drop:Get() return selected end
                function Drop:SetItems(i) items = i end
                function Drop:SetCallback(f) cb = f end
                if flag then NexusLib.Options[flag] = Drop end

                -- Single click handler — debounced toggle
                clickCatch.MouseButton1Click:Connect(function()
                    _withDebounce(function()
                        if open then Drop:Close() else Drop:Open() end
                    end)
                end)
                -- tbox.Focused fires when CaptureFocus succeeds inside Open —
                -- do NOT re-open here; only open if we weren't already open
                tbox.Focused:Connect(function()
                    if not open then
                        _withDebounce(function() Drop:Open() end)
                    end
                end)
                -- Outside-click closes
                AddConn(UserInputService.InputBegan:Connect(function(i)
                    if open and i.UserInputType == Enum.UserInputType.MouseButton1 then
                        task.defer(function()
                            if not widgetHolder:IsDescendantOf(gui) then return end
                            local mp = UserInputService:GetMouseLocation()
                            local lp = listOuter.AbsolutePosition
                            local ls = listOuter.AbsoluteSize
                            local wp = widgetHolder.AbsolutePosition
                            local ws = widgetHolder.AbsoluteSize
                            local inList   = mp.X>=lp.X and mp.X<=lp.X+ls.X
                                         and mp.Y>=lp.Y and mp.Y<=lp.Y+ls.Y
                            local inWidget = mp.X>=wp.X and mp.X<=wp.X+ws.X
                                         and mp.Y>=wp.Y and mp.Y<=wp.Y+ws.Y
                            if not inList and not inWidget then Drop:Close() end
                        end)
                    end
                end))
                AE(row); return Drop
            end

