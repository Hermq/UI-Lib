local function _attachAccordionElements(obj, inner, theme, onAdd, selfDepth)
    onAdd = onAdd or function() end

    local function nextLO()
        local n = 0
        for _, c in ipairs(inner:GetChildren()) do
            if c:IsA("Frame") then n = n + 1 end
        end
        return n + 1
    end

    function obj:AddButton(o)
        local n=o.Name or "Button"; local cb=o.Callback or function()end
        local row=MakeFrame({Size=UDim2.new(1,0,0,32),BackgroundTransparency=1,
            ZIndex=20+selfDepth,Parent=inner})
        row.LayoutOrder=nextLO()
        local btn=Instance.new("TextButton")
        btn.Size=UDim2.new(1,0,0,28); btn.Position=UDim2.new(0,0,0,2)
        btn.BackgroundColor3=theme.ElementBg; btn.Text=n
        btn.Font=Enum.Font.Gotham; btn.TextSize=12; btn.TextColor3=theme.TextPrimary
        btn.BorderSizePixel=0; btn.ZIndex=20+selfDepth; btn.AutoButtonColor=false; btn.Parent=row
        MakeCorner(btn,6); AddGlow(btn,theme)
        btn.MouseEnter:Connect(function() Tween(btn,{BackgroundColor3=theme.ElementHover},0.1) end)
        btn.MouseLeave:Connect(function() Tween(btn,{BackgroundColor3=theme.ElementBg},0.1) end)
        btn.MouseButton1Click:Connect(function()
            Tween(btn,{BackgroundColor3=theme.Accent},0.06)
            task.delay(0.12,function() Tween(btn,{BackgroundColor3=theme.ElementBg},0.15) end)
            cb()
        end)
        local B={}; function B:SetCallback(f) cb=f end
        onAdd(); return B
    end

    function obj:AddToggle(o)
        local n=o.Name or "Toggle"; local def=o.Default or false
        local flag=o.Flag; local cb=o.Callback or function()end; local st=def
        if flag then NexusLib.Flags[flag]=st end
        local row=MakeFrame({Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,
            ZIndex=20+selfDepth,Parent=inner})
        row.LayoutOrder=nextLO()
        local bg=Instance.new("TextButton")
        bg.Size=UDim2.new(1,0,0,30); bg.Position=UDim2.new(0,0,0,2)
        bg.BackgroundColor3=theme.ElementBg; bg.Text=""; bg.BorderSizePixel=0
        bg.ZIndex=20+selfDepth; bg.AutoButtonColor=false; bg.Parent=row
        MakeCorner(bg,6); AddGlow(bg,theme)
        local nl=MakeLabel({Size=UDim2.new(1,-54,1,0),Position=UDim2.new(0,10,0,0),
            Text=n,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=21+selfDepth,Parent=bg})
        nl.TextColor3=theme.TextPrimary
        local pill=MakeFrame({Size=UDim2.new(0,36,0,20),Position=UDim2.new(1,-44,0.5,-10),
            BackgroundColor3=st and theme.ToggleOn or theme.ToggleOff,
            ZIndex=21+selfDepth,Parent=bg})
        MakeCorner(pill,10)
        local dot=MakeFrame({Size=UDim2.new(0,14,0,14),
            Position=st and UDim2.new(0,19,0.5,-7) or UDim2.new(0,3,0.5,-7),
            BackgroundColor3=Color3.new(1,1,1),ZIndex=22+selfDepth,Parent=pill})
        MakeCorner(dot,7)
        local Tog={}
        local function SetSt(s,fire)
            st=s; if flag then NexusLib.Flags[flag]=s end
            Tween(pill,{BackgroundColor3=s and theme.ToggleOn or theme.ToggleOff},0.2)
            Tween(dot,{Size=UDim2.new(0,10,0,14)},0.07)
            task.delay(0.07,function()
                Tween(dot,{Position=s and UDim2.new(0,19,0.5,-7) or UDim2.new(0,3,0.5,-7)},
                    0.18,Enum.EasingStyle.Quart)
                TweenSpring(dot,{Size=UDim2.new(0,14,0,14)},0.25)
            end)
            if fire then cb(s) end
        end
        bg.MouseEnter:Connect(function() Tween(bg,{BackgroundColor3=theme.ElementHover},0.1) end)
        bg.MouseLeave:Connect(function() Tween(bg,{BackgroundColor3=theme.ElementBg},0.1) end)
        bg.MouseButton1Click:Connect(function() SetSt(not st,true) end)
        function Tog:Set(s) SetSt(s,false) end
        function Tog:Get() return st end
        function Tog:SetCallback(f) cb=f end
        if flag then NexusLib.Options[flag]=Tog end
        onAdd(); return Tog
    end

    function obj:AddSlider(o)
        local n=o.Name or "Slider"; local smin=o.Min or 0; local smax=o.Max or 100
        local def=o.Default or smin; local sfx=o.Suffix or ""; local flag=o.Flag
        local cb=o.Callback or function()end
        local val=math.clamp(def,smin,smax)
        if flag then NexusLib.Flags[flag]=val end
        local row=MakeFrame({Size=UDim2.new(1,0,0,52),BackgroundTransparency=1,
            ZIndex=20+selfDepth,Parent=inner})
        row.LayoutOrder=nextLO()
        local bg=MakeFrame({Size=UDim2.new(1,0,0,48),Position=UDim2.new(0,0,0,2),
            BackgroundColor3=theme.ElementBg,ZIndex=20+selfDepth,Parent=row})
        MakeCorner(bg,6)
        local nl=MakeLabel({Size=UDim2.new(0.6,0,0,18),Position=UDim2.new(0,10,0,5),
            Text=n,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=21+selfDepth,Parent=bg})
        nl.TextColor3=theme.TextPrimary
        local vLbl=MakeLabel({Size=UDim2.new(0.35,0,0,18),Position=UDim2.new(0.62,0,0,5),
            TextSize=12,Font=Enum.Font.GothamBold,
            TextXAlignment=Enum.TextXAlignment.Right,ZIndex=21+selfDepth,Parent=bg})
        vLbl.TextColor3=theme.Accent
        local track=MakeFrame({Size=UDim2.new(1,-18,0,6),Position=UDim2.new(0,9,0,30),
            BackgroundColor3=theme.TertiaryBg,ZIndex=21+selfDepth,Parent=bg})
        MakeCorner(track,3)
        local fill=MakeFrame({Size=UDim2.new(0,0,1,0),BackgroundColor3=theme.Accent,
            ZIndex=22+selfDepth,Parent=track})
        MakeCorner(fill,3)
        local thumb=MakeFrame({Size=UDim2.new(0,12,0,12),BackgroundColor3=Color3.new(1,1,1),
            ZIndex=23+selfDepth,Parent=track})
        MakeCorner(thumb,6)
        local Sli={}
        local function SV(v,fire)
            v=math.clamp(math.floor(v+0.5),smin,smax)
            val=v; if flag then NexusLib.Flags[flag]=v end
            local p=(smax>smin) and (v-smin)/(smax-smin) or 0
            fill.Size=UDim2.new(p,0,1,0)
            thumb.Position=UDim2.new(p,-6,0.5,-6)
            vLbl.Text=tostring(v)..sfx
            if fire then cb(v) end
        end
        SV(val,false)
        local sliding=false
        local function doSlide(x)
            local p=math.clamp((x-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1)
            SV(smin+(smax-smin)*p,true)
        end
        AddConn(track.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                sliding=true; doSlide(i.Position.X)
                TweenSpring(thumb,{Size=UDim2.new(0,16,0,16)},0.2)
            end
        end))
        AddConn(UserInputService.InputChanged:Connect(function(i)
            if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then doSlide(i.Position.X) end
        end))
        AddConn(UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 and sliding then
                sliding=false; TweenSine(thumb,{Size=UDim2.new(0,12,0,12)},0.15)
            end
        end))
        function Sli:Set(v) SV(v,false) end
        function Sli:Get() return val end
        function Sli:SetCallback(f) cb=f end
        if flag then NexusLib.Options[flag]=Sli end
        onAdd(); return Sli
    end

    function obj:AddKeybind(o)
        local n=o.Name or "Keybind"; local def=o.Default; local flag=o.Flag
        local cb=o.Callback or function()end
        local cur=def; local listening=false
        if flag then NexusLib.Flags[flag]=cur end
        local BLOCK={
            [Enum.KeyCode.Unknown]=true,[Enum.KeyCode.W]=true,
            [Enum.KeyCode.A]=true,[Enum.KeyCode.S]=true,[Enum.KeyCode.D]=true,
            [Enum.KeyCode.Space]=true,[Enum.KeyCode.Return]=true,
            [Enum.KeyCode.LeftShift]=true,[Enum.KeyCode.LeftControl]=true,
            [Enum.KeyCode.LeftAlt]=true,[Enum.KeyCode.RightAlt]=true,
        }
        local row=MakeFrame({Size=UDim2.new(1,0,0,32),BackgroundTransparency=1,
            ZIndex=20+selfDepth,Parent=inner})
        row.LayoutOrder=nextLO()
        local bg=MakeFrame({Size=UDim2.new(1,0,0,28),Position=UDim2.new(0,0,0,2),
            BackgroundColor3=theme.ElementBg,ZIndex=20+selfDepth,Parent=row})
        MakeCorner(bg,6); AddGlow(bg,theme)
        local nl=MakeLabel({Size=UDim2.new(0.54,0,1,0),Position=UDim2.new(0,10,0,0),
            Text=n,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=21+selfDepth,Parent=bg})
        nl.TextColor3=theme.TextPrimary
        local kbtn=Instance.new("TextButton")
        kbtn.Size=UDim2.new(0,90,0,20); kbtn.Position=UDim2.new(1,-98,0.5,-10)
        kbtn.Text=cur and cur.Name or "None"; kbtn.Font=Enum.Font.GothamBold
        kbtn.TextSize=11; kbtn.BorderSizePixel=0; kbtn.ZIndex=21+selfDepth
        kbtn.AutoButtonColor=false
        kbtn.BackgroundColor3=theme.TertiaryBg; kbtn.TextColor3=theme.TextSecondary
        kbtn.Parent=bg; MakeCorner(kbtn,5); AddHoverScale(kbtn); AddPressScale(kbtn)
        kbtn.MouseButton1Click:Connect(function()
            listening=true; NexusLib._listening=true
            kbtn.Text="..."; kbtn.TextColor3=theme.Accent
        end)
        AddConn(UserInputService.InputBegan:Connect(function(inp,gp)
            if listening then
                if inp.UserInputType~=Enum.UserInputType.Keyboard then return end
                listening=false; NexusLib._listening=false
                if inp.KeyCode==Enum.KeyCode.Escape then
                    cur=nil; if flag then NexusLib.Flags[flag]=nil end
                    kbtn.Text="None"; kbtn.TextColor3=theme.TextSecondary
                elseif BLOCK[inp.KeyCode] then
                    kbtn.Text=cur and cur.Name or "None"; kbtn.TextColor3=theme.TextSecondary
                else
                    cur=inp.KeyCode; if flag then NexusLib.Flags[flag]=cur end
                    kbtn.Text=cur.Name; kbtn.TextColor3=theme.Accent
                    task.delay(0.4,function() kbtn.TextColor3=theme.TextSecondary end)
                end
            else
                if NexusLib._listening then return end
                if not gp and inp.UserInputType==Enum.UserInputType.Keyboard
                    and cur and inp.KeyCode==cur then cb() end
            end
        end))
        local KB={}
        function KB:Set(k) cur=k; if flag then NexusLib.Flags[flag]=k end
            kbtn.Text=k and k.Name or "None" end
        function KB:Get() return cur end
        function KB:SetCallback(f) cb=f end
        if flag then NexusLib.Options[flag]=KB end
        onAdd(); return KB
    end

    function obj:AddAccordion(o)
        return NexusLib._makeAccordion(inner, theme, o.Name or "Group", selfDepth + 1, onAdd)
    end
end

function NexusLib._makeAccordion(parentContainer, theme, name, depth, parentRemeasure)
    depth           = depth or 0
    parentRemeasure = parentRemeasure or function() end

    local HDR_H   = math.max(36 - depth * 3, 28)
    local HDR_COL = depth == 0 and theme.SecondaryBg or theme.TertiaryBg
    local BAR_W   = math.max(4 - depth, 2)
    local FONT    = depth == 0 and Enum.Font.GothamBold or Enum.Font.Gotham
    local FSIZE   = math.max(13 - depth, 11)
    local PAD_V   = math.max(7 - depth * 2, 3)
    local PAD_H   = math.max(6 - depth, 2)

    local row = MakeFrame({
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex            = 10 + depth,
        Parent            = parentContainer,
    })
    row.LayoutOrder = #parentContainer:GetChildren()

    local header = Instance.new("TextButton")
    header.Size = UDim2.new(1, 0, 0, HDR_H)
    header.BackgroundColor3 = HDR_COL
    header.Text = ""; header.BorderSizePixel = 0
    header.AutoButtonColor = false; header.ZIndex = 11 + depth
    header.Parent = row
    MakeCorner(header, math.max(8 - depth * 2, 4))

    local acBar = MakeFrame({
        Size             = UDim2.new(0, BAR_W, 1, -math.floor(HDR_H * 0.4)),
        Position         = UDim2.new(0, 0, 0, math.floor(HDR_H * 0.2)),
        BackgroundColor3 = theme.Accent,
        ZIndex           = 12 + depth, Parent = header,
    })
    MakeCorner(acBar, 3)

    local nameLbl = MakeLabel({
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, BAR_W + 8, 0, 0),
        Text = name, Font = FONT, TextSize = FSIZE,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 12 + depth, Parent = header,
    })
    nameLbl.TextColor3 = depth == 0 and theme.TextPrimary or theme.TextSecondary

    local arrow = MakeLabel({
        Size = UDim2.new(0, 22, 1, 0), Position = UDim2.new(1, -24, 0, 0),
        Text = "▸", Font = Enum.Font.GothamBold,
        TextSize = math.max(13 - depth, 10),
        ZIndex = 12 + depth, Parent = header,
    })
    arrow.TextColor3 = theme.TextDim

    local clip = MakeFrame({
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, HDR_H + 2),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 10 + depth, Parent = row,
    })

    local inner = MakeFrame({
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex = 10 + depth, Parent = clip,
    })

    local ll = Instance.new("UIListLayout")
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.Padding   = UDim.new(0, math.max(5 - depth, 2))
    ll.Parent    = inner

    local pd = Instance.new("UIPadding")
    pd.PaddingTop    = UDim.new(0, PAD_V)
    pd.PaddingBottom = UDim.new(0, PAD_V)
    pd.PaddingLeft   = UDim.new(0, PAD_H)
    pd.PaddingRight  = UDim.new(0, PAD_H)
    pd.Parent        = inner

    local expanded = false
    local Acc = {}

    local function remeasure()
        if not expanded then return end
        task.wait()
        local h = inner.AbsoluteSize.Y
        Tween(clip, {Size = UDim2.new(1, 0, 0, h)}, 0.14)
        task.delay(0.16, parentRemeasure)
    end

    local function doExpand()
        expanded = true
        task.wait()
        local h = inner.AbsoluteSize.Y
        Tween(clip,   {Size = UDim2.new(1, 0, 0, h)}, 0.22)
        Tween(arrow,  {Rotation = 90}, 0.18)
        Tween(header, {BackgroundColor3 = theme.ElementHover}, 0.12)
        acBar.BackgroundColor3 = theme.AccentBar
        task.delay(0.24, parentRemeasure)
    end

    local function doCollapse()
        expanded = false
        Tween(clip,   {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
        Tween(arrow,  {Rotation = 0}, 0.18)
        Tween(header, {BackgroundColor3 = HDR_COL}, 0.12)
        acBar.BackgroundColor3 = theme.Accent
        task.delay(0.20, parentRemeasure)
    end

    header.MouseButton1Click:Connect(function()
        if expanded then doCollapse() else task.spawn(doExpand) end
    end)
    header.MouseEnter:Connect(function()
        if not expanded then Tween(header,{BackgroundColor3=theme.ElementHover},0.1) end
    end)
    header.MouseLeave:Connect(function()
        if not expanded then Tween(header,{BackgroundColor3=HDR_COL},0.1) end
    end)

    _attachAccordionElements(Acc, inner, theme, remeasure, depth)

    function Acc:AddAccordion(o)
        return NexusLib._makeAccordion(inner, theme, o.Name or "Group", depth + 1, remeasure)
    end

    Acc._remeasure = remeasure
    return Acc
end

-- ═══════════════════════════════════════════════════════════
--  CreateWindow
-- ═══════════════════════════════════════════════════════════
function NexusLib:CreateWindow(opts)
    local theme=opts.Theme
    if type(theme)=="string" then theme=self.Themes[theme] or self._theme
    elseif type(theme)~="table" then theme=self._theme end

    local winName   = opts.Name      or "Script"
    local winW      = (opts.Size and opts.Size.X) or 580
    local winH      = (opts.Size and opts.Size.Y) or 400
    local toggleKey = opts.ToggleKey
    local statusTxt = opts.Status    or ""
    local bgUrl     = opts.CustomBackground
    local TBAR,SBAR,TABW = 40,22,130

    local _refs={}
    local function R(obj,prop,key)
        table.insert(_refs,{obj,prop,key})
        pcall(function() obj[prop]=theme[key] end)
    end

    -- FIX 1: ClipsDescendants=true prevents elements floating outside during animations
    local mainFrame=MakeFrame({Name="NexusWindow",
        Size=UDim2.new(0,winW*0.96,0,winH*0.96),
        Position=UDim2.new(0.5,-winW*0.96/2,0.5,-winH*0.96/2),
        ZIndex=10, ClipsDescendants=true,
        BackgroundTransparency=1,Parent=gui})
    R(mainFrame,"BackgroundColor3","Background"); MakeCorner(mainFrame,10)

    -- FIX 4: Background image inside mainFrame so it clips with the window
    local bgImage = nil
    if bgUrl and type(bgUrl)=="string" and bgUrl~="" then
        bgImage = Instance.new("ImageLabel")
        bgImage.Size=UDim2.new(1,0,1,0); bgImage.BackgroundTransparency=1
        bgImage.Image=bgUrl; bgImage.ImageTransparency=0.65
        bgImage.ScaleType=Enum.ScaleType.Crop; bgImage.ZIndex=10; bgImage.Parent=mainFrame
        MakeCorner(bgImage,10)
    end

    TweenSpring(mainFrame,{
        Size=UDim2.new(0,winW,0,winH),
        Position=UDim2.new(0.5,-winW/2,0.5,-winH/2),
        BackgroundTransparency=0
    },0.45)

    local tbar=MakeFrame({Name="TitleBar",Size=UDim2.new(1,0,0,TBAR),ZIndex=11,Parent=mainFrame})
    R(tbar,"BackgroundColor3","SecondaryBg"); MakeCorner(tbar,10)
    local tbarPatch=MakeFrame({Size=UDim2.new(1,0,0,12),Position=UDim2.new(0,0,1,-12),ZIndex=11,Parent=tbar})
    R(tbarPatch,"BackgroundColor3","SecondaryBg")
    local accentLine=MakeFrame({Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-1),ZIndex=12,Parent=tbar})
    R(accentLine,"BackgroundColor3","Accent")
    local statusDot=MakeFrame({Size=UDim2.new(0,7,0,7),Position=UDim2.new(0,10,0.5,-3),ZIndex=13,Parent=tbar})
    R(statusDot,"BackgroundColor3","TextDim"); MakeCorner(statusDot,4)
    local titleLbl=MakeLabel({Size=UDim2.new(1,-90,1,0),Position=UDim2.new(0,24,0,0),
        Text=winName,Font=Enum.Font.GothamBold,TextSize=14,ZIndex=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=tbar})
    R(titleLbl,"TextColor3","TextPrimary")

    local minBtn=Instance.new("TextButton")
    minBtn.Size=UDim2.new(0,28,0,28); minBtn.Position=UDim2.new(1,-62,0.5,-14)
    minBtn.Text="−"; minBtn.Font=Enum.Font.GothamBold; minBtn.TextSize=18
    minBtn.BorderSizePixel=0; minBtn.ZIndex=13; minBtn.AutoButtonColor=false; minBtn.Parent=tbar
    R(minBtn,"BackgroundColor3","TertiaryBg"); R(minBtn,"TextColor3","TextSecondary"); MakeCorner(minBtn,6)

    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,28,0,28); closeBtn.Position=UDim2.new(1,-30,0.5,-14)
    closeBtn.BackgroundColor3=Color3.fromRGB(180,50,50); closeBtn.Text="×"
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.TextSize=20
    closeBtn.TextColor3=Color3.fromRGB(255,255,255); closeBtn.BorderSizePixel=0
    closeBtn.ZIndex=13; closeBtn.AutoButtonColor=false; closeBtn.Parent=tbar; MakeCorner(closeBtn,6)

    minBtn.MouseEnter:Connect(function() Tween(minBtn,{BackgroundColor3=theme.ElementHover},0.1) end)
    minBtn.MouseLeave:Connect(function() Tween(minBtn,{BackgroundColor3=theme.TertiaryBg},0.1) end)
    closeBtn.MouseEnter:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(220,70,70)},0.1) end)
    closeBtn.MouseLeave:Connect(function() Tween(closeBtn,{BackgroundColor3=Color3.fromRGB(180,50,50)},0.1) end)
    AddPressScale(minBtn); AddPressScale(closeBtn)

    local body=MakeFrame({Name="Body",Size=UDim2.new(1,0,0,winH-TBAR-SBAR),
        Position=UDim2.new(0,0,0,TBAR),ZIndex=10,ClipsDescendants=true,Parent=mainFrame})
    R(body,"BackgroundColor3","Background")

    local sbar=MakeFrame({Name="StatusBar",Size=UDim2.new(1,0,0,SBAR),
        Position=UDim2.new(0,0,1,-SBAR),ZIndex=11,Parent=mainFrame})
    R(sbar,"BackgroundColor3","SecondaryBg")
    local sbarBorder=MakeFrame({Size=UDim2.new(1,0,0,1),ZIndex=12,Parent=sbar})
    R(sbarBorder,"BackgroundColor3","Border")
    local sbarLbl=MakeLabel({Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,10,0,0),
        Text=statusTxt,TextSize=11,ZIndex=12,TextXAlignment=Enum.TextXAlignment.Left,Parent=sbar})
    R(sbarLbl,"TextColor3","TextDim")

    local sidebar=MakeFrame({Name="Sidebar",Size=UDim2.new(0,TABW,1,0),ZIndex=11,Parent=body})
    R(sidebar,"BackgroundColor3","SecondaryBg")
    -- Slight transparency if a background image is set so it bleeds through nicely
    if bgUrl and bgUrl~="" then sidebar.BackgroundTransparency=0.12 end

    local tabLL=Instance.new("UIListLayout"); tabLL.SortOrder=Enum.SortOrder.LayoutOrder
    tabLL.Padding=UDim.new(0,3); tabLL.Parent=sidebar
    local tabPd=Instance.new("UIPadding"); tabPd.PaddingTop=UDim.new(0,8)
    tabPd.PaddingLeft=UDim.new(0,6); tabPd.PaddingRight=UDim.new(0,6); tabPd.Parent=sidebar

    local pageHolder=MakeFrame({Name="Pages",Size=UDim2.new(1,-TABW,1,0),
        Position=UDim2.new(0,TABW,0,0),BackgroundTransparency=1,
        ZIndex=10,ClipsDescendants=true,Parent=body})

    local Win={_frame=mainFrame,_theme=theme,_tabs={},_minimized=false,_refs=_refs}

    -- Dragging
    local dragging,dragStart,startPos=false,nil,nil
    AddConn(tbar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true; dragStart=i.Position; startPos=mainFrame.Position
        end
    end))
    AddConn(UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-dragStart
            mainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,
                startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end))
    AddConn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end))

    -- FIX 3: Minimize — fade body out THEN shrink; restore: expand THEN reveal body
    minBtn.MouseButton1Click:Connect(function()
        Win._minimized = not Win._minimized
        if Win._minimized then
            Tween(body,{BackgroundTransparency=1},0.14)
            task.delay(0.15,function()
                body.Visible=false; sbar.Visible=false
                body.BackgroundTransparency=0
                Tween(mainFrame,{Size=UDim2.new(0,winW,0,TBAR)},0.20,Enum.EasingStyle.Quart)
            end)
        else
            Tween(mainFrame,{Size=UDim2.new(0,winW,0,winH)},0.22,Enum.EasingStyle.Quart)
            task.delay(0.23,function()
                sbar.Visible=true; body.Visible=true
                body.BackgroundTransparency=1
                TweenSine(body,{BackgroundTransparency=0},0.18)
            end)
        end
    end)

    -- FIX 2: Close tween
    closeBtn.MouseButton1Click:Connect(function()
        Tween(mainFrame,{
            Size=UDim2.new(0,winW*0.9,0,winH*0.9),
            BackgroundTransparency=1
        },0.24,Enum.EasingStyle.Quint)
        task.delay(0.26,function() mainFrame:Destroy() end)
    end)

    if toggleKey then
        AddConn(UserInputService.InputBegan:Connect(function(i,gp)
            if NexusLib._listening then return end
            if not gp and i.UserInputType==Enum.UserInputType.Keyboard and i.KeyCode==toggleKey then
                Win:ToggleVisible()
            end
        end))
    end

    -- ── Win methods ──────────────────────────────────────
    function Win:ToggleVisible()
        if not mainFrame or not mainFrame.Parent then return end
        if mainFrame.Visible then
            TweenSine(mainFrame,{BackgroundTransparency=1},0.18)
            task.delay(0.20,function()
                mainFrame.Visible=false; mainFrame.BackgroundTransparency=0
            end)
        else
            mainFrame.BackgroundTransparency=1; mainFrame.Visible=true
            TweenSine(mainFrame,{BackgroundTransparency=0},0.22)
        end
    end

    function Win:SetStatus(text,dotColor)
        sbarLbl.Text=text or ""
        if dotColor then Tween(statusDot,{BackgroundColor3=dotColor},0.2) end
    end

    function Win:SetTheme(t)
        local nt=type(t)=="string" and NexusLib.Themes[t] or t
        if not nt then return end
        theme=nt; Win._theme=nt
        for _,r in ipairs(_refs) do
            pcall(function() r[1][r[2]]=theme[r[3]] end)
        end
    end

    function Win:SetBackground(url)
        url = url or ""
        url = url:match("^%s*(.-)%s*$")
        if url ~= "" then
            if url:match("^%d+$") then url = "rbxassetid://"..url end
            if url:match("^https?://") then
                warn("[NexusLib] SetBackground: use rbxassetid://, not HTTP URLs"); url=""
            end
        end
        if bgImage then bgImage.Image = url
        elseif url ~= "" then
            bgImage=Instance.new("ImageLabel")
            bgImage.Size=UDim2.new(1,0,1,0); bgImage.BackgroundTransparency=1
            bgImage.Image=url; bgImage.ImageTransparency=0.65
            bgImage.ScaleType=Enum.ScaleType.Crop; bgImage.ZIndex=10
            bgImage.Parent=mainFrame; MakeCorner(bgImage,10)
        end
    end

    function Win:Destroy()
        if mainFrame and mainFrame.Parent then mainFrame:Destroy() end
    end

    -- ════════════════════════════════════════════════════════
    --  AddTab  — TAB FIX (v2.5)
    --
    --  Uses a plain Frame (pageWrap) instead of CanvasGroup.
    --  Tab pages are shown/hidden via instant .Visible toggle.
    --  No GroupTransparency, no reserved height, no artifacts.
    -- ════════════════════════════════════════════════════════
    function Win:AddTab(opts)
        local tName=opts.Name or "Tab"
        local tIcon=opts.Icon

        -- Sidebar button
        local tbtn=Instance.new("TextButton")
        tbtn.Name="TBtn_"..tName; tbtn.Size=UDim2.new(1,0,0,34)
        tbtn.BackgroundTransparency=1; tbtn.BorderSizePixel=0
        tbtn.LayoutOrder=#Win._tabs+1; tbtn.ZIndex=12
        tbtn.AutoButtonColor=false; tbtn.Parent=sidebar
        MakeCorner(tbtn,6)

